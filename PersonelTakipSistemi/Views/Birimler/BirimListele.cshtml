@model PersonelTakipSistemi.ViewModels.BirimListeleViewModel
@{
    ViewData["Title"] = "Birimleri Listele";
    var initialShowsKomisyon = Model.DefaultKoordinatorlukId.HasValue;
    var initialTitle = initialShowsKomisyon ? "Komisyonlar" : "Koordinatörlükler";
    var initialIcon = initialShowsKomisyon ? "bx bxs-group me-2 text-primary" : "bx bxs-grid-alt me-2 text-primary";
}

<style>
    .turkey-map-container {
        position: relative;
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
    }

    #svg-turkiye-haritasi {
        width: 100%;
        height: auto;
    }

    #svg-turkiye-haritasi g[data-plakakodu] {
        transition: transform 0.2s ease;
        transform-box: fill-box;
        transform-origin: center;
    }

    #svg-turkiye-haritasi g[data-plakakodu] path {
        fill: #c5cdd3;
        stroke: #fff;
        stroke-width: 0.5;
        transition: fill 0.3s ease;
        cursor: default;
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-clickable path {
        cursor: pointer;
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-disabled path {
        cursor: default;
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-hover {
        transform: scale(1.01);
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-hover path {
        opacity: 0.8;
    }

    .map-active-merkez path {
        fill: #3498db !important;
    }

    .map-active-tasra path {
        fill: #e74c3c !important;
    }

    .no-organization path {
        fill: #c5cdd3 !important;
    }

    .selected-il-merkez path {
        fill: #2980b9 !important;
        stroke: #2c3e50 !important;
        stroke-width: 2px !important;
    }

    .selected-il-tasra path {
        fill: #c0392b !important;
        stroke: #2c3e50 !important;
        stroke-width: 2px !important;
    }

    .map-tooltip {
        position: absolute;
        background: rgba(44, 62, 80, 0.9);
        color: #fff;
        padding: 8px 15px;
        border-radius: 5px;
        font-size: 0.9rem;
        font-weight: 500;
        pointer-events: none;
        display: none;
        z-index: 1050;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .birim-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
        background: #fff;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .birim-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.12);
        border-color: #3498db;
    }

    .birim-card .card-body {
        padding: 1.5rem;
    }

    .birim-card .birim-ad {
        font-weight: 700;
        font-size: 1rem;
        color: #2c3e50;
        margin-bottom: 0.6rem;
        line-height: 1.3;
    }

    .birim-card .birim-il {
        font-size: 0.8rem;
        color: #7f8c8d;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .birim-card .stats-row {
        display: flex;
        justify-content: flex-start;
        gap: 1.25rem;
        padding-top: 1rem;
        border-top: 1px solid #f0f0f0;
    }

    .birim-card .stat-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .birim-card .stat-value {
        font-weight: 800;
        font-size: 1.2rem;
        color: #2c3e50;
    }

    .birim-card .stat-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #95a5a6;
    }

    .birim-filter-bar {
        background: #fff;
        padding: 1.25rem;
        border-radius: 12px;
        box-shadow: 0 4px 25px rgba(0,0,0,0.06);
        margin-bottom: 2rem;
        border: 1px solid rgba(0,0,0,0.02);
    }

    .map-legend {
        display: flex;
        gap: 2rem;
        justify-content: center;
        margin-top: 1.5rem;
        padding: 1rem;
        background: rgba(255,255,255,0.5);
        border-radius: 10px;
    }

    .map-legend span {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #444;
    }

    .legend-box {
        width: 14px;
        height: 14px;
        border-radius: 3px;
    }

    .personel-table-card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .personel-table-card .table {
        margin-bottom: 0;
    }

    .personel-table-card th {
        background: #d9dcdf;
        color: #3f4b59;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0;
        white-space: nowrap;
    }

    .personel-table-card td {
        vertical-align: middle;
        color: #657180;
        font-size: .9rem;
    }

    .personel-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #696cff;
        color: #fff;
        font-weight: 700;
        font-size: .75rem;
    }

    .personel-actions {
        display: inline-flex;
        gap: .5rem;
        flex-wrap: nowrap;
        white-space: nowrap;
    }

    .personel-action-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: 0;
    }

    .personel-action-btn i {
        font-size: 1.45rem;
        line-height: 1;
    }

    .personel-row-highlight {
        animation: personelHighlight 3s ease forwards;
    }

    @@keyframes personelHighlight {
        0%, 70% { background: rgba(3, 169, 244, .18); }
        100% { background: transparent; }
    }

    .personel-table-footer {
        border-top: 1px solid #eef0f2;
    }

    .personel-yetki-panel .offcanvas-body {
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }

    .yetki-personel-summary {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem .5rem .75rem;
    }

    .yetki-personel-logo {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #696cff;
        background: #f0f1ff;
        font-size: 1.7rem;
    }

    .yetki-list {
        display: flex;
        flex-direction: column;
        gap: .65rem;
        min-height: 58px;
    }

    .yetki-role-card {
        border: 1px solid #696cff;
        border-radius: 8px;
        background: #f7f7ff;
        padding: .75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
    }

    .yetki-role-title {
        font-weight: 700;
        color: #566a7f;
        line-height: 1.2;
    }

    .yetki-role-context {
        color: #697a8d;
        font-size: .78rem;
        line-height: 1.35;
        margin-top: .2rem;
    }

    .yetki-role-actions {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        flex-shrink: 0;
    }

    .yetki-role-actions .btn {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .yetki-add-card {
        border: 1px solid #eef0f2;
        border-radius: 8px;
        box-shadow: 0 4px 16px rgba(67, 89, 113, .08);
        padding: 1rem;
        background: #fff;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <button type="button" class="btn btn-outline-secondary btn-sm mb-2 d-none" id="pageBackButton" onclick="pageGeriDon()">
            <i class="bx bx-left-arrow-alt me-1"></i>Geri Dön
        </button>
        <h4 class="mb-1 text-primary fw-bold" id="pageTitle">Birim Haritası ve Listesi</h4>
        <p class="text-muted small mb-0">Organizasyon yapısını harita ve filtreler üzerinden inceleyin</p>
    </div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Birimler/Ayarlar">Birimler</a></li>
            <li class="breadcrumb-item active">Birim Listele</li>
        </ol>
    </nav>
</div>

<div class="birim-filter-bar row g-3">
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Daire Başkanlığı</label>
        <select id="filterDaire" class="form-select border-light-subtle shadow-sm">
            <option value="">Tümü</option>
            @foreach (var d in Model.DaireList)
            {
                <option value="@d.Value" selected="@(d.Value == Model.DefaultDaireBaskanligiId?.ToString() ? "selected" : null)">@d.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Teşkilat</label>
        <select id="filterTeskilat" class="form-select border-light-subtle shadow-sm">
            <option value="">Seçiniz</option>
            @foreach (var t in Model.TeskilatList)
            {
                <option value="@t.Value" selected="@(t.Value == Model.DefaultTeskilatId?.ToString() ? "selected" : null)">@t.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Koordinatörlük</label>
        <select id="filterKoordinatorluk" class="form-select border-light-subtle shadow-sm">
            <option value="">Seçiniz</option>
            @foreach (var k in Model.KoordinatorlukList)
            {
                <option value="@k.Value" selected="@(k.Selected ? "selected" : null)">@k.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Komisyon</label>
        <select id="filterKomisyon" class="form-select border-light-subtle shadow-sm">
            <option value="">Seçiniz</option>
            @foreach (var k in Model.KomisyonList)
            {
                <option value="@k.Value" selected="@(k.Selected ? "selected" : null)">@k.Text</option>
            }
        </select>
    </div>
</div>

<div class="card border-0 shadow-sm mb-5" style="border-radius: 15px; overflow: hidden;">
    <div class="card-body p-4">
        <div class="turkey-map-container" id="mapContainer">
            <div class="map-tooltip" id="mapTooltip"></div>
            <partial name="_TurkeyMap" />
        </div>
        <div class="map-legend">
            <span><div class="legend-box" style="background:#e74c3c;"></div> İl Koordinatörlükleri (Taşra)</span>
            <span><div class="legend-box" style="background:#3498db;"></div> Merkez Birim Komisyonları</span>
            <span><div class="legend-box" style="background:#c5cdd3;"></div> Birim/Komisyon Yok</span>
        </div>
    </div>
</div>

<div class="card personel-table-card" id="birimPersonelCard">
    <div class="card-header d-flex justify-content-between align-items-center bg-white">
        <h6 class="mb-0"><i class="bx bxs-user-detail me-2 text-primary"></i>Personeller</h6>
        <button type="button" class="btn btn-sm btn-primary" onclick="topluEkleAc()">
            <i class="bx bx-user-plus me-1"></i>Ekle
        </button>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Foto</th>
                    <th>Ad Soyad</th>
                    <th>Kullanılan Yazılımlar</th>
                    <th>Uzmanlık</th>
                    <th>Görev Türü</th>
                    <th>İş Niteliği</th>
                    <th id="personelYerHeader1">Görevli İl</th>
                    <th id="personelYerHeader2">Kadro Yeri</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody id="birimPersonelBody">
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">Personeller yükleniyor...</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white personel-table-footer d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted small" id="personelKayitBilgi">0 kayıt</span>
            <select class="form-select form-select-sm" id="personelPageSize" style="width: 82px;">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="20">20</option>
            </select>
        </div>
        <ul class="pagination pagination-sm mb-0" id="personelPagination"></ul>
    </div>
</div>

<div class="row align-items-center mb-4">
    <div class="col">
        <div class="d-flex align-items-center gap-3">
            <button id="btnGeriDon" class="btn btn-outline-secondary btn-sm @(initialShowsKomisyon ? string.Empty : "d-none")" onclick="geriDon()">
                <i class="bx bx-left-arrow-alt me-1"></i> Geri Dön
            </button>
            <h5 id="kartBaslik" class="mb-0 fw-bold"><i class="@initialIcon"></i>@initialTitle</h5>
        </div>
    </div>
    <div class="col-auto">
        <span class="badge bg-label-primary px-3 py-2" id="kartSayisi">@Model.Kartlar.Count birim</span>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="kartContainer">
    @foreach (var k in Model.Kartlar)
    {
        var merkezKomisyonKarti = Model.DefaultTeskilatId == 1 && k.Tur == "Komisyon" && !string.IsNullOrEmpty(k.IlAdi);
        var kartBaslik = merkezKomisyonKarti ? $"{k.IlAdi} Komisyonu" : k.Ad;
        var altBilgi = merkezKomisyonKarti ? k.Ad.Replace(" Komisyonu", "") : k.IlAdi;
        var altBilgiIkon = merkezKomisyonKarti ? "bx bx-category" : "bx bx-map-pin";

        <div class="col">
            <div class="card birim-card h-100" onclick="birimKartTiklandi('@k.Tur', @k.Id)">
                <div class="card-body">
                    <div class="birim-ad">@kartBaslik</div>
                    @if (!string.IsNullOrEmpty(altBilgi))
                    {
                        <div class="birim-il"><i class="@altBilgiIkon"></i> @altBilgi</div>
                    }
                    <div class="stats-row">
                        <div class="stat-item">
                            <span class="stat-value">@k.PersonelSayisi</span>
                            <span class="stat-label">Personel</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value" style="color: #ff9f43;">@k.GorevSayisi</span>
                            <span class="stat-label">Görev</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="topluPersonelEkleDrawer" aria-labelledby="topluPersonelEkleLabel" style="width: 560px;">
    <div class="offcanvas-header border-bottom">
        <h5 id="topluPersonelEkleLabel" class="offcanvas-title">Toplu Personel Ekle</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
    </div>
    <div class="offcanvas-body">
        <div class="mb-3 p-3 bg-light rounded">
            <div class="small text-muted">Hedef Birim</div>
            <div class="fw-bold" id="topluEkleHedef">-</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Personel Ara</label>
            <input type="text" class="form-control" id="topluPersonelAra" placeholder="Ad, soyad veya il ile ara">
        </div>
        <div class="mb-3">
            <label class="form-label">Personeller</label>
            <select class="form-select" id="topluPersonelSelect" multiple size="12"></select>
            <small class="text-muted">Ctrl veya Shift ile birden fazla personel seçebilirsiniz.</small>
        </div>
    </div>
    <div class="offcanvas-footer p-3 border-top d-flex gap-2 bg-light">
        <button type="button" class="btn btn-label-secondary w-50" data-bs-dismiss="offcanvas">Kapat</button>
        <button type="button" class="btn btn-primary w-50" id="topluEkleKaydetBtn" onclick="topluEkleKaydet()">Ekle</button>
    </div>
</div>

<div class="offcanvas offcanvas-end personel-yetki-panel" tabindex="-1" id="hizliYetkilendirmeDrawer" aria-labelledby="hizliYetkilendirmeLabel" style="width: 520px; max-width: 100vw;">
    <div class="offcanvas-header border-bottom">
        <h5 id="hizliYetkilendirmeLabel" class="offcanvas-title">Personel Yetkilendirme</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
    </div>
    <div class="offcanvas-body">
        <input type="hidden" id="yetkiPersonelId" />
        <input type="hidden" id="yetkiCurrentKomisyonId" />

        <div class="yetki-personel-summary">
            <div class="yetki-personel-logo">
                <i class="bx bx-user-check"></i>
            </div>
            <div>
                <div class="fw-semibold" id="yetkiPersonelAd"></div>
                <div class="small text-muted" id="yetkiSistemRol">-</div>
            </div>
        </div>

        <ul class="nav nav-tabs nav-fill mb-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" type="button">Kurumsal Atamalar</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link disabled" type="button" aria-disabled="true">Sistemsel Yetki</button>
            </li>
        </ul>

        <div class="small fw-bold text-muted text-uppercase mb-2">Mevcut Yetkiler</div>
        <div id="yetkiMevcutRoller" class="yetki-list mb-3">
            <span class="text-muted">Yetkiler yükleniyor...</span>
        </div>

        <div class="yetki-add-card">
            <div class="fw-semibold text-primary mb-3">
                <i class="bx bx-plus-circle me-1"></i>Yeni Yetki Tanımla
            </div>
            <div class="mb-2">
                <select class="form-select" id="yetkiTeskilat">
                    <option value="">Teşkilat Seçiniz...</option>
                </select>
            </div>
            <div class="mb-2">
                <select class="form-select" id="yetkiKoordinatorluk" disabled>
                    <option value="">Koordinatörlük Seçiniz...</option>
                </select>
            </div>
            <div class="mb-2">
                <select class="form-select" id="yetkiKomisyon" disabled>
                    <option value="">Komisyon Seçiniz (İsteğe Bağlı)...</option>
                </select>
            </div>
            <div class="mb-3">
                <select class="form-select" id="yetkiRolSelect">
                    <option value="">Rol Seçiniz...</option>
                </select>
            </div>
            <button type="button" class="btn btn-primary w-100" id="yetkiRolEkleBtn" onclick="hizliRolEkle()">
                <i class="bx bx-check me-1"></i>Yetki Ekle
            </button>
        </div>
    </div>
    <div class="offcanvas-footer p-3 border-top d-flex gap-2 bg-light">
        <button type="button" class="btn btn-label-secondary w-100" data-bs-dismiss="offcanvas">Kapat</button>
    </div>
</div>

@section Scripts {
    <script>
        let selectedIlId = null;
        let currentTeskilatId = @(Model.DefaultTeskilatId ?? 0);
        let defaultKoordId = @(Model.DefaultKoordinatorlukId ?? 0);
        let activeIlIds = [];
        let illerData = @Html.Raw(Json.Serialize(Model.Iller));
        let lastRenderedKartlar = @Html.Raw(Json.Serialize(Model.Kartlar));
        let currentPersonelScope = { type: 'Teskilat', id: currentTeskilatId || 0 };
        let hizliYetkiDrawer = null;
        let topluEkleDrawer = null;
        let birimPersoneller = [];
        let personelCurrentPage = 1;
        let personelPageSize = 10;
        let highlightPersonelIds = [];
        let topluEkleSearchTimer = null;

        $(document).ready(function() {
            hizliYetkiDrawer = new bootstrap.Offcanvas(document.getElementById('hizliYetkilendirmeDrawer'));
            topluEkleDrawer = new bootstrap.Offcanvas(document.getElementById('topluPersonelEkleDrawer'));
            initMapInteractions();

            if (currentTeskilatId) {
                const initialKoordId = parseNullableInt($('#filterKoordinatorluk').val()) || defaultKoordId || null;
                updateMapStatus(currentTeskilatId, initialKoordId);
            }

            loadPersoneller();

            $('#personelPageSize').on('change', function() {
                personelPageSize = parseInt($(this).val(), 10) || 10;
                personelCurrentPage = 1;
                renderPersoneller();
            });

            $('#topluPersonelAra').on('input', function() {
                clearTimeout(topluEkleSearchTimer);
                topluEkleSearchTimer = setTimeout(() => loadTopluPersonelOptions($(this).val()), 250);
            });
        });

        function parseNullableInt(value) {
            const parsed = parseInt(value, 10);
            return Number.isNaN(parsed) ? null : parsed;
        }

        function escapeHtml(value) {
            return (value || '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function formatList(values) {
            return values && values.length ? escapeHtml(values.join(', ')) : '-';
        }

        function formatLimitedList(values) {
            if (!values || !values.length) return '-';

            const ordered = [...values].sort((a, b) => a.length - b.length || a.localeCompare(b, 'tr'));
            const first = escapeHtml(ordered[0]);
            if (ordered.length === 1) return first;

            const rest = ordered.slice(1).map(x => `<span class="badge bg-label-secondary me-1">${escapeHtml(x)}</span>`).join('');
            return `
                <span class="limited-first">${first}</span>
                <button type="button" class="badge bg-primary border-0 ms-1" onclick="toggleLimitedList(this)">...</button>
                <span class="limited-more d-none">${rest}<button type="button" class="badge bg-secondary border-0 ms-1" onclick="toggleLimitedList(this)">X</button></span>
            `;
        }

        function toggleLimitedList(button) {
            event.stopPropagation();
            const $button = $(button);
            const $more = $button.siblings('.limited-more');
            if ($more.length) {
                $button.addClass('d-none');
                $more.removeClass('d-none');
                return;
            }

            const $container = $button.closest('.limited-more');
            $container.addClass('d-none');
            $container.siblings('button').removeClass('d-none');
        }

        function getCurrentScope() {
            const komId = parseNullableInt($('#filterKomisyon').val());
            const koordId = parseNullableInt($('#filterKoordinatorluk').val());
            const tesId = parseNullableInt($('#filterTeskilat').val());

            if (komId) return { type: 'Komisyon', id: komId };
            if (koordId) return { type: 'Koordinatorluk', id: koordId };
            if (tesId) return { type: 'Teskilat', id: tesId };
            return { type: '', id: 0 };
        }

        function isIlInteractive(ilId) {
            return activeIlIds.includes(ilId);
        }

        function initMapInteractions() {
            const $cities = $('#mapContainer svg g[data-plakakodu]');
            const $tooltip = $('#mapTooltip');

            $cities.on('mouseenter', function() {
                const ilId = parseNullableInt($(this).attr('data-plakakodu'));
                const ilAd = getCityName(ilId, $(this).attr('data-iladi'));
                if (!ilAd) {
                    return;
                }

                $(this).addClass('map-hover');
                $tooltip.text(ilAd).show();
            });

            $cities.on('mousemove', function(e) {
                const rect = document.getElementById('mapContainer').getBoundingClientRect();
                $tooltip.css({
                    left: (e.clientX - rect.left + 15) + 'px',
                    top: (e.clientY - rect.top - 40) + 'px'
                });
            });

            $cities.on('mouseleave', function() {
                $(this).removeClass('map-hover');
                $tooltip.hide();
            });

            $cities.on('click', function() {
                const ilId = parseNullableInt($(this).attr('data-plakakodu'));
                const ilAd = getCityName(ilId, $(this).attr('data-iladi'));

                if (ilId !== null) {
                    onIlClick(ilId, ilAd);
                }
            });
        }

        function getCityName(ilId, fallbackName = '') {
            if (ilId === null) {
                return fallbackName || '';
            }

            const il = illerData.find(x => x.ilId === ilId);
            return il?.ad || fallbackName || '';
        }

        function updateMapStatus(tesId, koordId = null) {
            if (!tesId) {
                activeIlIds = [];
                applyMapColors();
                return;
            }

            if (tesId == 1 && !koordId) {
                activeIlIds = [6];
                applyMapColors();
                return;
            }

            $.get('/Birimler/GetIllerDurumu', { teskilatId: tesId, koordinatorlukId: koordId }, function(data) {
                activeIlIds = data;
                applyMapColors();
            });
        }

        function applyMapColors() {
            const $cities = $('#mapContainer svg g[data-plakakodu]');
            const isMerkez = currentTeskilatId == 1;
            const isTasra = currentTeskilatId == 2;

            $cities.each(function() {
                const plaka = parseNullableInt($(this).attr('data-plakakodu'));
                if (plaka === null) {
                    return;
                }

                const isActive = activeIlIds.includes(plaka);

                $(this).removeClass('map-active-merkez map-active-tasra no-organization selected-il-merkez selected-il-tasra map-clickable map-disabled');

                if (isActive) {
                    if (isMerkez) {
                        $(this).addClass('map-active-merkez');
                    } else if (isTasra) {
                        $(this).addClass('map-active-tasra');
                    }

                    $(this).addClass('map-clickable');
                } else {
                    $(this).addClass('no-organization map-disabled');
                }

                if (selectedIlId === plaka && isActive) {
                    if (isMerkez) {
                        $(this).addClass('selected-il-merkez');
                    } else if (isTasra) {
                        $(this).addClass('selected-il-tasra');
                    }
                }
            });
        }

        function onIlClick(ilId, ilAd) {
            if (!isIlInteractive(ilId)) {
                return;
            }

            const koordId = parseNullableInt($('#filterKoordinatorluk').val());

            if (currentTeskilatId == 1 && !koordId) {
                if (ilId === 6) {
                    selectedIlId = selectedIlId === 6 ? null : 6;
                    applyMapColors();

                    if (selectedIlId === 6) {
                        $('html, body').animate({
                            scrollTop: $("#kartBaslik").offset().top - 100
                        }, 500);
                    }
                }
                return;
            }

            if (currentTeskilatId == 1 && koordId) {
                const nextSelectedIlId = selectedIlId === ilId ? null : ilId;

                if (nextSelectedIlId === null) {
                    selectedIlId = null;
                    applyMapColors();
                    loadKartlar();
                    return;
                }

                const currentCommission = findSingleCommissionForIl(ilId);
                if (currentCommission) {
                    window.location.href = '/Birimler/KomisyonDetay/' + currentCommission.id;
                    return;
                }

                $.get('/Birimler/GetBirimKartlari', { koordinatorlukId: koordId, ilId: ilId }, function(data) {
                    if (data && data.length === 1 && data[0].tur === 'Komisyon') {
                        window.location.href = '/Birimler/KomisyonDetay/' + data[0].id;
                        return;
                    }

                    selectedIlId = nextSelectedIlId;
                    applyMapColors();
                    lastRenderedKartlar = data || [];
                    renderKartlar(lastRenderedKartlar);
                    scrollToKartlar();
                });
                return;
            }

            if (currentTeskilatId == 1 || currentTeskilatId == 2) {
                if (currentTeskilatId == 2 && !koordId) {
                    $.get('/Birimler/GetBirimKartlari', { teskilatId: currentTeskilatId, ilId: ilId }, function(data) {
                        const koordinatorlukler = (data || []).filter(x => x.tur === 'Koordinatorluk');
                        if (koordinatorlukler.length === 1) {
                            selectedIlId = ilId;
                            applyMapColors();
                            selectKoordinatorluk(koordinatorlukler[0].id, koordinatorlukler[0].ad);
                            return;
                        }

                        selectedIlId = selectedIlId === ilId ? null : ilId;
                        applyMapColors();
                        lastRenderedKartlar = koordinatorlukler;
                        renderKartlar(lastRenderedKartlar);
                        scrollToKartlar();
                    });
                    return;
                }

                selectedIlId = selectedIlId === ilId ? null : ilId;
                applyMapColors();
                loadKartlar();
                scrollToKartlar();
            }
        }

        $('#filterDaire').change(function() {
            const daireId = $(this).val();
            const $tes = $('#filterTeskilat');
            $tes.empty().append('<option value="">Teşkilat Seçiniz</option>');

            if (daireId) {
                $.get('/Birimler/GetTeskilatlar?daireId=' + daireId, function(data) {
                    data.forEach(t => $tes.append(new Option(t.ad, t.teskilatId)));
                    $tes.trigger('change');
                });
            } else {
                $tes.trigger('change');
            }
        });

        $('#filterTeskilat').change(function() {
            const tesId = parseNullableInt($(this).val());
            currentTeskilatId = tesId || 0;
            selectedIlId = null;

            updateMapStatus(currentTeskilatId);
            fillKoordinatorlukler(currentTeskilatId);
            loadKartlar();
            loadPersoneller();
        });

        function fillKoordinatorlukler(tesId, selectedKId = null) {
            const $koord = $('#filterKoordinatorluk');
            const $kom = $('#filterKomisyon');
            $koord.empty().append('<option value="">Seçiniz</option>').prop('disabled', !tesId);
            $kom.empty().append('<option value="">Seçiniz</option>').prop('disabled', true);

            if (tesId) {
                $.get('/Birimler/GetKoordinatorlukler?teskilatId=' + tesId, function(data) {
                    data.forEach(x => {
                        const opt = new Option(x.ad, x.koordinatorlukId);
                        if (selectedKId && x.koordinatorlukId == selectedKId) {
                            opt.selected = true;
                        }
                        $koord.append(opt);
                    });

                    if (selectedKId) {
                        $koord.trigger('change');
                    }
                });
            }
        }

        $('#filterKoordinatorluk').change(function() {
            const koordId = parseNullableInt($(this).val());
            const $kom = $('#filterKomisyon');
            $kom.empty().append('<option value="">Seçiniz</option>').prop('disabled', !koordId);

            selectedIlId = null;
            updateMapStatus(currentTeskilatId, koordId);

            if (koordId) {
                $.get('/Birimler/GetKomisyonlar?koordinatorlukId=' + koordId, function(data) {
                    data.forEach(x => $kom.append(new Option(x.ad, x.komisyonId)));
                });
            }

            loadKartlar();
            loadPersoneller();
        });

        $('#filterKomisyon').change(function() {
            loadPersoneller();
        });

        function loadKartlar() {
            const tesId = parseNullableInt($('#filterTeskilat').val());
            const koordId = parseNullableInt($('#filterKoordinatorluk').val());

            let url = '/Birimler/GetBirimKartlari?';
            if (koordId) {
                url += 'koordinatorlukId=' + koordId;
                if (selectedIlId) {
                    url += '&ilId=' + selectedIlId;
                }
            } else if (tesId) {
                url += 'teskilatId=' + tesId;
                if (selectedIlId) {
                    url += '&ilId=' + selectedIlId;
                }
            }

            $.get(url, function(data) {
                lastRenderedKartlar = data || [];
                renderKartlar(lastRenderedKartlar);
            });
        }

        function loadPersoneller() {
            const scope = getCurrentScope();
            currentPersonelScope = scope;
            const canListPersonel = scope.type === 'Koordinatorluk' || scope.type === 'Komisyon';
            const $body = $('#birimPersonelBody');
            $body.html('<tr><td colspan="9" class="text-center text-muted py-4">Personeller yükleniyor...</td></tr>');
            $('#personelKayitBilgi').text('0 kayıt');
            $('#personelPagination').empty();

            if (!scope.id || !canListPersonel) {
                birimPersoneller = [];
                $('#birimPersonelCard').addClass('d-none');
                return;
            }

            $('#birimPersonelCard').removeClass('d-none');

            let url = '/Birimler/GetBirimPersoneller?';
            if (scope.type === 'Komisyon') url += 'komisyonId=' + scope.id;
            else if (scope.type === 'Koordinatorluk') url += 'koordinatorlukId=' + scope.id;

            $.get(url, function(data) {
                birimPersoneller = data || [];
                personelCurrentPage = 1;
                renderPersoneller();
            }).fail(function() {
                birimPersoneller = [];
                $body.html('<tr><td colspan="9" class="text-center text-danger py-4">Personeller yüklenemedi.</td></tr>');
            });
        }

        function renderPersoneller() {
            const personeller = birimPersoneller || [];
            const scope = currentPersonelScope;
            const $body = $('#birimPersonelBody');
            const isKoordinatorlukList = scope.type === 'Koordinatorluk';
            $body.empty();
            $('#personelKayitBilgi').text(personeller.length + ' kayıt');
            $('#personelYerHeader1').text(isKoordinatorlukList ? 'GÖREV YERİ' : 'GÖREVLİ İL');
            $('#personelYerHeader2').text(isKoordinatorlukList ? '' : 'KADRO YERİ');

            if (!personeller.length) {
                $body.html('<tr><td colspan="9" class="text-center text-muted py-4">Bu birimde kayıtlı personel bulunmuyor.</td></tr>');
                $('#personelPagination').empty();
                return;
            }

            const totalPages = Math.max(1, Math.ceil(personeller.length / personelPageSize));
            personelCurrentPage = Math.min(Math.max(1, personelCurrentPage), totalPages);
            const startIndex = (personelCurrentPage - 1) * personelPageSize;
            const pageItems = personeller.slice(startIndex, startIndex + personelPageSize);

            pageItems.forEach(p => {
                const names = (p.adSoyad || '').split(' ').filter(Boolean);
                const initials = ((names[0] || '?')[0] || '?') + ((names[names.length - 1] || '')[0] || '');
                const canRemove = scope.type !== 'Teskilat';
                const rowClass = highlightPersonelIds.includes(p.personelId) ? 'personel-row-highlight' : '';
                const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                const personelUrl = `/Personel/Detay/${p.personelId}?returnUrl=${returnUrl}&returnLabel=${encodeURIComponent('Birim Listesine Dön')}`;
                const removeButton = canRemove
                    ? `<button type="button" class="btn btn-sm btn-danger personel-action-btn" title="Çıkar" data-bs-toggle="tooltip" onclick="birimdenCikar(${p.personelId})"><i class="bx bx-user-minus"></i></button>`
                    : '';
                const yerCells = isKoordinatorlukList
                    ? `<td colspan="2">${formatLimitedList(p.gorevYerleri)}</td>`
                    : `<td>${escapeHtml(p.gorevliIl || '-')}</td><td>${escapeHtml(p.kadroYeri || '-')}</td>`;

                const html = `
                    <tr class="${rowClass}" data-personel-id="${p.personelId}">
                        <td><span class="personel-avatar">${escapeHtml(initials.toUpperCase())}</span></td>
                        <td class="fw-semibold"><a class="text-dark" href="${personelUrl}">${escapeHtml(p.adSoyad)}</a></td>
                        <td>${formatList(p.yazilimlar)}</td>
                        <td>${formatList(p.uzmanliklar)}</td>
                        <td>${formatList(p.gorevTurleri)}</td>
                        <td>${formatList(p.isNitelikleri)}</td>
                        ${yerCells}
                        <td class="text-end">
                            <div class="personel-actions justify-content-end">
                                <button type="button" class="btn btn-sm btn-info personel-action-btn text-white" title="Yetkilendir" data-bs-toggle="tooltip" onclick="hizliYetkilendirAc(${p.personelId}, '${escapeHtml(p.adSoyad)}')"><i class="bx bx-user-check"></i></button>
                                ${removeButton}
                            </div>
                        </td>
                    </tr>
                `;
                $body.append(html);
            });

            document.querySelectorAll('#birimPersonelBody [data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
            renderPersonelPagination(totalPages);

            if (highlightPersonelIds.length) {
                setTimeout(() => {
                    $('.personel-row-highlight').removeClass('personel-row-highlight');
                    highlightPersonelIds = [];
                }, 3000);
            }
        }

        function renderPersonelPagination(totalPages) {
            const $pagination = $('#personelPagination');
            $pagination.empty();
            if (totalPages <= 1) return;

            const addPage = (label, page, disabled, active) => {
                $pagination.append(`
                    <li class="page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}">
                        <button type="button" class="page-link" onclick="changePersonelPage(${page})">${label}</button>
                    </li>
                `);
            };

            addPage('&laquo;', Math.max(1, personelCurrentPage - 1), personelCurrentPage === 1, false);
            for (let i = 1; i <= totalPages; i++) {
                addPage(i, i, false, i === personelCurrentPage);
            }
            addPage('&raquo;', Math.min(totalPages, personelCurrentPage + 1), personelCurrentPage === totalPages, false);
        }

        function changePersonelPage(page) {
            personelCurrentPage = page;
            renderPersoneller();
        }

        function renderKartlar(kartlar) {
            const $container = $('#kartContainer');
            $container.empty();

            if (!kartlar || kartlar.length === 0) {
                $container.html('<div class="col-12 no-data-msg text-center p-5"><i class="bx bx-info-circle fs-1 d-block mb-3 text-muted"></i>Bir birim bulunamadı.</div>');
                $('#kartSayisi').text('0 birim');
                $('#pageBackButton').addClass('d-none');
                $('#btnGeriDon').addClass('d-none');
                $('#pageBackButton').addClass('d-none');
                $('#pageTitle').text('Birim Haritası ve Listesi');
                return;
            }

            $('#kartSayisi').text(kartlar.length + ' birim');

            if (kartlar[0].tur === 'Komisyon') {
                $('#kartBaslik').html('<i class="bx bxs-group me-2 text-primary"></i>Komisyonlar');
                $('#pageBackButton').removeClass('d-none');
                $('#btnGeriDon').removeClass('d-none');
            } else {
                $('#kartBaslik').html('<i class="bx bxs-grid-alt me-2 text-primary"></i>Koordinatörlükler');
                $('#btnGeriDon').addClass('d-none');
            }

            kartlar.forEach(k => {
                let displayedTitle = k.ad;
                let secondaryText = k.ilAdi || '';
                let secondaryIcon = 'bx bx-map-pin';

                if (currentTeskilatId == 1 && k.tur === 'Komisyon' && k.ilAdi) {
                    displayedTitle = `${k.ilAdi} Komisyonu`;
                    secondaryText = (k.ad || '').replace(' Komisyonu', '');
                    secondaryIcon = 'bx bx-category';
                }

                const ilBadge = secondaryText ? `<div class="birim-il"><i class="${secondaryIcon}"></i> ${secondaryText}</div>` : '';
                const html = `
                    <div class="col">
                        <div class="card birim-card h-100" onclick="birimKartTiklandi('${k.tur}', ${k.id})">
                            <div class="card-body">
                                <div class="birim-ad">${displayedTitle}</div>
                                ${ilBadge}
                                <div class="stats-row">
                                    <div class="stat-item">
                                        <span class="stat-value">${k.personelSayisi}</span>
                                        <span class="stat-label">Personel</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-value" style="color: #ff9f43;">${k.gorevSayisi}</span>
                                        <span class="stat-label">Görev</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                $container.append(html);
            });
        }

        function birimKartTiklandi(tur, id) {
            if (tur === 'Komisyon') {
                window.location.href = '/Birimler/KomisyonDetay/' + id;
            } else if (tur === 'Koordinatorluk') {
                selectKoordinatorluk(id);
            }
        }

        function selectKoordinatorluk(id, ad) {
            if ($('#filterKoordinatorluk option[value="' + id + '"]').length === 0 && ad) {
                $('#filterKoordinatorluk').append(new Option(ad, id));
            }

            $('#filterKoordinatorluk').val(id).trigger('change');
            setTimeout(() => {
                const selectedText = $('#filterKoordinatorluk option:selected').text() || ad || 'Koordinatörlük';
                $('#pageTitle').text(selectedText);
                $('#pageBackButton').removeClass('d-none');
                $('#kartBaslik').html('<i class="bx bxs-grid-alt me-2 text-primary"></i>' + escapeHtml(selectedText));
                $('#btnGeriDon').removeClass('d-none');
                $('html, body').animate({
                    scrollTop: Math.max(0, $("#pageTitle").offset().top - 80)
                }, 450);
            }, 160);
        }

        function birimdenCikar(personelId) {
            if (!currentPersonelScope.id || currentPersonelScope.type === 'Teskilat') {
                return;
            }

            Swal.fire({
                title: 'Personel çıkarılsın mı?',
                text: currentPersonelScope.type === 'Komisyon'
                    ? 'Personel komisyondan çıkarılır, koordinatörlük kaydı korunur.'
                    : 'Personel koordinatörlükten çıkarılır, teşkilat kaydı korunur.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Çıkar',
                cancelButtonText: 'İptal'
            }).then(result => {
                if (!result.isConfirmed) return;

                $.post('/Birimler/BirimPersonelCikar', {
                    personelId: personelId,
                    scopeType: currentPersonelScope.type,
                    scopeId: currentPersonelScope.id
                }).done(function() {
                    loadPersoneller();
                    loadKartlar();
                    Swal.fire({ icon: 'success', title: 'Çıkarıldı', toast: true, position: 'top-end', timer: 1800, showConfirmButton: false });
                }).fail(function(xhr) {
                    Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'İşlem tamamlanamadı.', 'error');
                });
            });
        }

        function hizliYetkilendirAc(personelId, adSoyad) {
            const currentKoordId = parseNullableInt($('#filterKoordinatorluk').val());
            const currentKomId = parseNullableInt($('#filterKomisyon').val());

            $('#yetkiPersonelId').val(personelId);
            $('#yetkiCurrentKomisyonId').val(currentKomId || '');
            $('#yetkiPersonelAd').text(adSoyad);
            $('#yetkiSistemRol').text('-');
            $('#yetkiMevcutRoller').html('<span class="text-muted">Yetkiler yükleniyor...</span>');
            $('#yetkiRolSelect').empty().append('<option value="">Rol Seçiniz...</option>');
            $('#yetkiTeskilat').empty().append('<option value="">Teşkilat Seçiniz...</option>');
            $('#yetkiKoordinatorluk').empty().append('<option value="">Koordinatörlük Seçiniz...</option>').prop('disabled', true);
            $('#yetkiKomisyon').empty().append('<option value="">Komisyon Seçiniz (İsteğe Bağlı)...</option>').prop('disabled', true);

            $.get('/Birimler/GetBirimPersonelYetkiData', {
                personelId: personelId,
                koordinatorlukId: currentKoordId,
                komisyonId: currentKomId
            }, function(data) {
                renderBirimYetkiData(data);
                hizliYetkiDrawer.show();
            }).fail(function(xhr) {
                Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Yetki bilgileri yüklenemedi.', 'error');
            });
        }

        $('#yetkiTeskilat').change(function() {
            fillYetkiKoordinatorlukler(parseNullableInt($(this).val()), null, null);
        });

        $('#yetkiKoordinatorluk').change(function() {
            fillYetkiKomisyonlar(parseNullableInt($(this).val()), null);
        });

        function renderBirimYetkiData(data) {
            $('#yetkiPersonelAd').text(data.adSoyad || $('#yetkiPersonelAd').text());
            $('#yetkiSistemRol').text(data.sistemRol || '-');
            renderBirimRoller(data.roles || []);

            const $rol = $('#yetkiRolSelect');
            $rol.empty().append('<option value="">Rol Seçiniz...</option>');
            (data.roleOptions || []).forEach(role => $rol.append(new Option(role.ad, role.id)));

            const $tes = $('#yetkiTeskilat');
            $tes.empty().append('<option value="">Teşkilat Seçiniz...</option>');
            (data.teskilatOptions || []).forEach(t => {
                const opt = new Option(t.ad, t.id);
                if (data.selectedTeskilatId && t.id == data.selectedTeskilatId) {
                    opt.selected = true;
                }
                $tes.append(opt);
            });

            fillYetkiKoordinatorlukler(data.selectedTeskilatId, data.selectedKoordinatorlukId, data.selectedKomisyonId);
        }

        function renderBirimRoller(roles) {
            const $roles = $('#yetkiMevcutRoller');
            $roles.empty();

            if (!roles.length) {
                $roles.html('<div class="text-muted small border rounded p-3">Bu personele tanımlı kurumsal yetki bulunmuyor.</div>');
                return;
            }

            roles.forEach(role => {
                $roles.append(`
                    <div class="yetki-role-card">
                        <div>
                            <div class="yetki-role-title">${escapeHtml(role.rolAd)}</div>
                            <div class="yetki-role-context">${escapeHtml(role.contextAd || 'Genel')}</div>
                        </div>
                        <div class="yetki-role-actions">
                            <button type="button" class="btn btn-sm btn-label-secondary" title="Düzenle" disabled>
                                <i class="bx bx-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-label-danger" title="Yetkiyi kaldır" onclick="hizliRolSil(${role.assignmentId})">
                                <i class="bx bx-x"></i>
                            </button>
                        </div>
                    </div>
                `);
            });
        }

        function fillYetkiKoordinatorlukler(teskilatId, selectedKoordId, selectedKomId) {
            const $koord = $('#yetkiKoordinatorluk');
            const $kom = $('#yetkiKomisyon');
            $koord.empty().append('<option value="">Koordinatörlük Seçiniz...</option>').prop('disabled', !teskilatId);
            $kom.empty().append('<option value="">Komisyon Seçiniz (İsteğe Bağlı)...</option>').prop('disabled', true);

            if (!teskilatId) return;

            $.get('/Birimler/GetKoordinatorlukler', { teskilatId }, function(data) {
                data.forEach(x => {
                    const opt = new Option(x.ad, x.koordinatorlukId);
                    if (selectedKoordId && x.koordinatorlukId == selectedKoordId) {
                        opt.selected = true;
                    }
                    $koord.append(opt);
                });

                if (selectedKoordId) {
                    fillYetkiKomisyonlar(selectedKoordId, selectedKomId);
                }
            });
        }

        function fillYetkiKomisyonlar(koordId, selectedKomId) {
            const $kom = $('#yetkiKomisyon');
            $kom.empty().append('<option value="">Komisyon Seçiniz (İsteğe Bağlı)...</option>').prop('disabled', !koordId);
            if (!koordId) return;

            $.get('/Birimler/GetKomisyonlarForYetkilendirme', { koordinatorlukId: koordId }, function(data) {
                data.forEach(x => {
                    const opt = new Option(x.ad, x.komisyonId);
                    if (selectedKomId && x.komisyonId == selectedKomId) {
                        opt.selected = true;
                    }
                    $kom.append(opt);
                });
            });
        }

        function hizliRolEkle(force = false) {
            const personelId = parseNullableInt($('#yetkiPersonelId').val());
            const kurumsalRolId = parseNullableInt($('#yetkiRolSelect').val());
            const komisyonId = parseNullableInt($('#yetkiKomisyon').val());
            const koordinatorlukId = komisyonId ? null : parseNullableInt($('#yetkiKoordinatorluk').val());

            if (!personelId || !kurumsalRolId) {
                Swal.fire('Eksik Bilgi', 'Eklemek için rol seçiniz.', 'warning');
                return;
            }

            if (!koordinatorlukId && !komisyonId) {
                Swal.fire('Eksik Bilgi', 'Koordinatörlük veya komisyon seçiniz.', 'warning');
                return;
            }

            $('#yetkiRolEkleBtn').prop('disabled', true);
            $.post('/Birimler/BirimPersonelRolEkle', {
                personelId,
                kurumsalRolId,
                koordinatorlukId,
                komisyonId,
                force
            }).done(function(response) {
                if (response && response.warning) {
                    Swal.fire({
                        title: 'Uyarı',
                        text: response.warning,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Evet, Değiştir',
                        cancelButtonText: 'İptal'
                    }).then(result => {
                        if (result.isConfirmed) {
                            hizliRolEkle(true);
                        }
                    });
                    return;
                }

                hizliYetkilendirAc(personelId, $('#yetkiPersonelAd').text());
                loadPersoneller();
                loadKartlar();
                Swal.fire({ icon: 'success', title: 'Yetki eklendi', toast: true, position: 'top-end', timer: 1800, showConfirmButton: false });
            }).fail(function(xhr) {
                Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Yetki eklenemedi.', 'error');
            }).always(function() {
                $('#yetkiRolEkleBtn').prop('disabled', false);
            });
        }

        function hizliRolSil(assignmentId) {
            $.post('/Birimler/BirimPersonelRolSil', { assignmentId })
                .done(function() {
                    const personelId = parseNullableInt($('#yetkiPersonelId').val());
                    hizliYetkilendirAc(personelId, $('#yetkiPersonelAd').text());
                    loadPersoneller();
                    loadKartlar();
                    Swal.fire({ icon: 'success', title: 'Yetki kaldırıldı', toast: true, position: 'top-end', timer: 1600, showConfirmButton: false });
                })
                .fail(function(xhr) {
                    Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Yetki kaldırılamadı.', 'error');
                });
        }

        function topluEkleAc() {
            const scope = getCurrentScope();
            if (!scope.id || (scope.type !== 'Koordinatorluk' && scope.type !== 'Komisyon')) {
                Swal.fire('Birim Seçiniz', 'Personel eklemek için önce koordinatörlük veya komisyon seçiniz.', 'warning');
                return;
            }

            currentPersonelScope = scope;
            const selectedText = scope.type === 'Komisyon'
                ? $('#filterKomisyon option:selected').text()
                : scope.type === 'Koordinatorluk'
                    ? $('#filterKoordinatorluk option:selected').text()
                    : $('#filterTeskilat option:selected').text();

            $('#topluEkleHedef').text(selectedText || scope.type);
            $('#topluPersonelAra').val('');
            $('#topluPersonelSelect').empty().append('<option>Personeller yükleniyor...</option>');
            loadTopluPersonelOptions('');
            topluEkleDrawer.show();
        }

        function loadTopluPersonelOptions(query) {
            $.get('/Birimler/GetTopluAtamaPersoneller', { q: query || '' }, function(data) {
                const $select = $('#topluPersonelSelect');
                $select.empty();
                (data || []).forEach(p => {
                    const label = p.adSoyad + (p.il ? ' - ' + p.il : '');
                    $select.append(new Option(label, p.personelId));
                });
            }).fail(function() {
                $('#topluPersonelSelect').empty().append('<option>Personeller yüklenemedi</option>');
            });
        }

        function topluEkleKaydet() {
            const selectedIds = ($('#topluPersonelSelect').val() || []).map(x => parseInt(x, 10)).filter(Boolean);
            const selectedName = $('#topluPersonelSelect option:selected').first().text().split(' - ')[0] || '';
            if (!selectedIds.length) {
                Swal.fire('Personel Seçiniz', 'Eklemek için en az bir personel seçiniz.', 'warning');
                return;
            }

            const scope = currentPersonelScope;
            const payload = {
                personelIds: selectedIds,
                teskilatId: scope.type === 'Teskilat' ? scope.id : null,
                koordinatorlukId: scope.type === 'Koordinatorluk' ? scope.id : (scope.type === 'Komisyon' ? parseNullableInt($('#filterKoordinatorluk').val()) : null),
                komisyonId: scope.type === 'Komisyon' ? scope.id : null
            };

            $('#topluEkleKaydetBtn').prop('disabled', true);
            $.ajax({
                url: '/Birimler/YapTopluAtama',
                type: 'POST',
                contentType: 'application/json; charset=utf-8',
                data: JSON.stringify(payload)
            }).done(function() {
                highlightPersonelIds = selectedIds;
                topluEkleDrawer.hide();
                loadPersoneller();
                loadKartlar();
                if (selectedIds.length === 1) {
                    setTimeout(() => hizliYetkilendirAc(selectedIds[0], selectedName), 350);
                }
                Swal.fire({ icon: 'success', title: 'Personel eklendi', toast: true, position: 'top-end', timer: 1800, showConfirmButton: false });
            }).fail(function(xhr) {
                Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Personel eklenemedi.', 'error');
            }).always(function() {
                $('#topluEkleKaydetBtn').prop('disabled', false);
            });
        }

        function findSingleCommissionForIl(ilId) {
            if (!Array.isArray(lastRenderedKartlar)) {
                return null;
            }

            const matches = lastRenderedKartlar.filter(k => k && k.tur === 'Komisyon' && k.ilId === ilId);
            return matches.length === 1 ? matches[0] : null;
        }

        function scrollToKartlar() {
            const scrollTarget = $("#kartBaslik").length ? $("#kartBaslik") : $("#kartContainer");
            $('html, body').animate({
                scrollTop: scrollTarget.offset().top - 100
            }, 500);
        }

        function geriDon() {
            $('#filterKoordinatorluk').val('').trigger('change');
            $('#pageBackButton').addClass('d-none');
            $('#pageTitle').text('Birim Haritası ve Listesi');
        }

        function pageGeriDon() {
            if ($('#filterKoordinatorluk').val()) {
                geriDon();
                $('html, body').animate({ scrollTop: 0 }, 450);
                return;
            }

            if (window.history.length > 1 && document.referrer && document.referrer !== window.location.href) {
                window.history.back();
                return;
            }

            geriDon();
        }
    </script>
}

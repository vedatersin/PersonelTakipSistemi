@model PersonelTakipSistemi.ViewModels.BirimListeleViewModel
@{
    ViewData["Title"] = "Birimleri Listele";
    var initialShowsKomisyon = Model.DefaultKoordinatorlukId.HasValue;
    var initialTitle = initialShowsKomisyon ? "Komisyonlar" : "Koordinatörlükler";
    var initialIcon = initialShowsKomisyon ? "bx bxs-group me-2 text-primary" : "bx bxs-grid-alt me-2 text-primary";
}

<style>
    .turkey-map-container {
        position: relative;
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
    }

    #svg-turkiye-haritasi {
        width: 100%;
        height: auto;
    }

    #svg-turkiye-haritasi g[data-plakakodu] {
        transition: transform 0.2s ease;
        transform-box: fill-box;
        transform-origin: center;
    }

    #svg-turkiye-haritasi g[data-plakakodu] path {
        fill: #c5cdd3;
        stroke: #fff;
        stroke-width: 0.5;
        transition: fill 0.3s ease;
        cursor: default;
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-clickable path {
        cursor: pointer;
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-disabled path {
        cursor: default;
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-hover {
        transform: scale(1.01);
    }

    #svg-turkiye-haritasi g[data-plakakodu].map-hover path {
        opacity: 0.8;
    }

    .map-active-merkez path {
        fill: #3498db !important;
    }

    .map-active-tasra path {
        fill: #e74c3c !important;
    }

    .no-organization path {
        fill: #c5cdd3 !important;
    }

    .selected-il-merkez path {
        fill: #2980b9 !important;
        stroke: #2c3e50 !important;
        stroke-width: 2px !important;
    }

    .selected-il-tasra path {
        fill: #c0392b !important;
        stroke: #2c3e50 !important;
        stroke-width: 2px !important;
    }

    .map-tooltip {
        position: absolute;
        background: rgba(44, 62, 80, 0.9);
        color: #fff;
        padding: 8px 15px;
        border-radius: 5px;
        font-size: 0.9rem;
        font-weight: 500;
        pointer-events: none;
        display: none;
        z-index: 1050;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .birim-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
        background: #fff;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .birim-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.12);
        border-color: #3498db;
    }

    .birim-card .card-body {
        padding: 1.5rem;
    }

    .birim-card .birim-ad {
        font-weight: 700;
        font-size: 1rem;
        color: #2c3e50;
        margin-bottom: 0.6rem;
        line-height: 1.3;
    }

    .birim-card .birim-il {
        font-size: 0.8rem;
        color: #7f8c8d;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .birim-card .stats-row {
        display: flex;
        justify-content: flex-start;
        gap: 1.25rem;
        padding-top: 1rem;
        border-top: 1px solid #f0f0f0;
    }

    .birim-card .stat-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .birim-card .stat-value {
        font-weight: 800;
        font-size: 1.2rem;
        color: #2c3e50;
    }

    .birim-card .stat-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #95a5a6;
    }

    .birim-filter-bar {
        background: #fff;
        padding: 1.25rem;
        border-radius: 12px;
        box-shadow: 0 4px 25px rgba(0,0,0,0.06);
        margin-bottom: 2rem;
        border: 1px solid rgba(0,0,0,0.02);
    }

    .map-legend {
        display: flex;
        gap: 2rem;
        justify-content: center;
        margin-top: 1.5rem;
        padding: 1rem;
        background: rgba(255,255,255,0.5);
        border-radius: 10px;
    }

    .map-legend span {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #444;
    }

    .legend-box {
        width: 14px;
        height: 14px;
        border-radius: 3px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 text-primary fw-bold">Birim Haritası ve Listesi</h4>
        <p class="text-muted small mb-0">Organizasyon yapısını harita ve filtreler üzerinden inceleyin</p>
    </div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Birimler/Ayarlar">Birimler</a></li>
            <li class="breadcrumb-item active">Birim Listele</li>
        </ol>
    </nav>
</div>

<div class="birim-filter-bar row g-3">
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Daire Başkanlığı</label>
        <select id="filterDaire" class="form-select border-light-subtle shadow-sm">
            <option value="">Tümü</option>
            @foreach (var d in Model.DaireList)
            {
                <option value="@d.Value" selected="@(d.Value == Model.DefaultDaireBaskanligiId?.ToString() ? "selected" : null)">@d.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Teşkilat</label>
        <select id="filterTeskilat" class="form-select border-light-subtle shadow-sm">
            <option value="">Seçiniz</option>
            @foreach (var t in Model.TeskilatList)
            {
                <option value="@t.Value" selected="@(t.Value == Model.DefaultTeskilatId?.ToString() ? "selected" : null)">@t.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Koordinatörlük</label>
        <select id="filterKoordinatorluk" class="form-select border-light-subtle shadow-sm">
            <option value="">Seçiniz</option>
            @foreach (var k in Model.KoordinatorlukList)
            {
                <option value="@k.Value" selected="@(k.Selected ? "selected" : null)">@k.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small fw-bold text-muted">Komisyon</label>
        <select id="filterKomisyon" class="form-select border-light-subtle shadow-sm">
            <option value="">Seçiniz</option>
            @foreach (var k in Model.KomisyonList)
            {
                <option value="@k.Value" selected="@(k.Selected ? "selected" : null)">@k.Text</option>
            }
        </select>
    </div>
</div>

<div class="card border-0 shadow-sm mb-5" style="border-radius: 15px; overflow: hidden;">
    <div class="card-body p-4">
        <div class="turkey-map-container" id="mapContainer">
            <div class="map-tooltip" id="mapTooltip"></div>
            <partial name="_TurkeyMap" />
        </div>
        <div class="map-legend">
            <span><div class="legend-box" style="background:#e74c3c;"></div> İl Koordinatörlükleri (Taşra)</span>
            <span><div class="legend-box" style="background:#3498db;"></div> Merkez Birim Komisyonları</span>
            <span><div class="legend-box" style="background:#c5cdd3;"></div> Birim/Komisyon Yok</span>
        </div>
    </div>
</div>

<div class="row align-items-center mb-4">
    <div class="col">
        <div class="d-flex align-items-center gap-3">
            <button id="btnGeriDon" class="btn btn-outline-secondary btn-sm @(initialShowsKomisyon ? string.Empty : "d-none")" onclick="geriDon()">
                <i class="bx bx-left-arrow-alt me-1"></i> Geri Dön
            </button>
            <h5 id="kartBaslik" class="mb-0 fw-bold"><i class="@initialIcon"></i>@initialTitle</h5>
        </div>
    </div>
    <div class="col-auto">
        <span class="badge bg-label-primary px-3 py-2" id="kartSayisi">@Model.Kartlar.Count birim</span>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="kartContainer">
    @foreach (var k in Model.Kartlar)
    {
        <div class="col">
            <div class="card birim-card h-100" onclick="birimKartTiklandi('@k.Tur', @k.Id)">
                <div class="card-body">
                    <div class="birim-ad">@k.Ad</div>
                    @if (!string.IsNullOrEmpty(k.IlAdi))
                    {
                        <div class="birim-il"><i class="bx bx-map-pin"></i> @k.IlAdi</div>
                    }
                    <div class="stats-row">
                        <div class="stat-item">
                            <span class="stat-value">@k.PersonelSayisi</span>
                            <span class="stat-label">Personel</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value" style="color: #ff9f43;">@k.GorevSayisi</span>
                            <span class="stat-label">Görev</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        let selectedIlId = null;
        let currentTeskilatId = @(Model.DefaultTeskilatId ?? 0);
        let defaultKoordId = @(Model.DefaultKoordinatorlukId ?? 0);
        let activeIlIds = [];
        let illerData = @Html.Raw(Json.Serialize(Model.Iller));
        let lastRenderedKartlar = @Html.Raw(Json.Serialize(Model.Kartlar));

        $(document).ready(function() {
            initMapInteractions();

            if (currentTeskilatId) {
                const initialKoordId = parseNullableInt($('#filterKoordinatorluk').val()) || defaultKoordId || null;
                updateMapStatus(currentTeskilatId, initialKoordId);
            }
        });

        function parseNullableInt(value) {
            const parsed = parseInt(value, 10);
            return Number.isNaN(parsed) ? null : parsed;
        }

        function isIlInteractive(ilId) {
            return activeIlIds.includes(ilId);
        }

        function initMapInteractions() {
            const $cities = $('#mapContainer svg g[data-plakakodu]');
            const $tooltip = $('#mapTooltip');

            $cities.on('mouseenter', function() {
                const ilId = parseNullableInt($(this).attr('data-plakakodu'));
                const ilAd = getCityName(ilId, $(this).attr('data-iladi'));
                if (!ilAd) {
                    return;
                }

                $(this).addClass('map-hover');
                $tooltip.text(ilAd).show();
            });

            $cities.on('mousemove', function(e) {
                const rect = document.getElementById('mapContainer').getBoundingClientRect();
                $tooltip.css({
                    left: (e.clientX - rect.left + 15) + 'px',
                    top: (e.clientY - rect.top - 40) + 'px'
                });
            });

            $cities.on('mouseleave', function() {
                $(this).removeClass('map-hover');
                $tooltip.hide();
            });

            $cities.on('click', function() {
                const ilId = parseNullableInt($(this).attr('data-plakakodu'));
                const ilAd = getCityName(ilId, $(this).attr('data-iladi'));

                if (ilId !== null) {
                    onIlClick(ilId, ilAd);
                }
            });
        }

        function getCityName(ilId, fallbackName = '') {
            if (ilId === null) {
                return fallbackName || '';
            }

            const il = illerData.find(x => x.ilId === ilId);
            return il?.ad || fallbackName || '';
        }

        function updateMapStatus(tesId, koordId = null) {
            if (!tesId) {
                activeIlIds = [];
                applyMapColors();
                return;
            }

            if (tesId == 1 && !koordId) {
                activeIlIds = [6];
                applyMapColors();
                return;
            }

            $.get('/Birimler/GetIllerDurumu', { teskilatId: tesId, koordinatorlukId: koordId }, function(data) {
                activeIlIds = data;
                applyMapColors();
            });
        }

        function applyMapColors() {
            const $cities = $('#mapContainer svg g[data-plakakodu]');
            const isMerkez = currentTeskilatId == 1;
            const isTasra = currentTeskilatId == 2;

            $cities.each(function() {
                const plaka = parseNullableInt($(this).attr('data-plakakodu'));
                if (plaka === null) {
                    return;
                }

                const isActive = activeIlIds.includes(plaka);

                $(this).removeClass('map-active-merkez map-active-tasra no-organization selected-il-merkez selected-il-tasra map-clickable map-disabled');

                if (isActive) {
                    if (isMerkez) {
                        $(this).addClass('map-active-merkez');
                    } else if (isTasra) {
                        $(this).addClass('map-active-tasra');
                    }

                    $(this).addClass('map-clickable');
                } else {
                    $(this).addClass('no-organization map-disabled');
                }

                if (selectedIlId === plaka && isActive) {
                    if (isMerkez) {
                        $(this).addClass('selected-il-merkez');
                    } else if (isTasra) {
                        $(this).addClass('selected-il-tasra');
                    }
                }
            });
        }

        function onIlClick(ilId, ilAd) {
            if (!isIlInteractive(ilId)) {
                return;
            }

            const koordId = parseNullableInt($('#filterKoordinatorluk').val());

            if (currentTeskilatId == 1 && !koordId) {
                if (ilId === 6) {
                    selectedIlId = selectedIlId === 6 ? null : 6;
                    applyMapColors();

                    if (selectedIlId === 6) {
                        $('html, body').animate({
                            scrollTop: $("#kartBaslik").offset().top - 100
                        }, 500);
                    }
                }
                return;
            }

            if (currentTeskilatId == 1 && koordId) {
                const nextSelectedIlId = selectedIlId === ilId ? null : ilId;

                if (nextSelectedIlId === null) {
                    selectedIlId = null;
                    applyMapColors();
                    loadKartlar();
                    return;
                }

                const currentCommission = findSingleCommissionForIl(ilId);
                if (currentCommission) {
                    window.location.href = '/Birimler/KomisyonDetay/' + currentCommission.id;
                    return;
                }

                $.get('/Birimler/GetBirimKartlari', { koordinatorlukId: koordId, ilId: ilId }, function(data) {
                    if (data && data.length === 1 && data[0].tur === 'Komisyon') {
                        window.location.href = '/Birimler/KomisyonDetay/' + data[0].id;
                        return;
                    }

                    selectedIlId = nextSelectedIlId;
                    applyMapColors();
                    lastRenderedKartlar = data || [];
                    renderKartlar(lastRenderedKartlar);
                    scrollToKartlar();
                });
                return;
            }

            if (currentTeskilatId == 1 || currentTeskilatId == 2) {
                selectedIlId = selectedIlId === ilId ? null : ilId;
                applyMapColors();
                loadKartlar();
                scrollToKartlar();
            }
        }

        $('#filterDaire').change(function() {
            const daireId = $(this).val();
            const $tes = $('#filterTeskilat');
            $tes.empty().append('<option value="">Teşkilat Seçiniz</option>');

            if (daireId) {
                $.get('/Birimler/GetTeskilatlar?daireId=' + daireId, function(data) {
                    data.forEach(t => $tes.append(new Option(t.ad, t.teskilatId)));
                    $tes.trigger('change');
                });
            } else {
                $tes.trigger('change');
            }
        });

        $('#filterTeskilat').change(function() {
            const tesId = parseNullableInt($(this).val());
            currentTeskilatId = tesId || 0;
            selectedIlId = null;

            updateMapStatus(currentTeskilatId);
            fillKoordinatorlukler(currentTeskilatId);
            loadKartlar();
        });

        function fillKoordinatorlukler(tesId, selectedKId = null) {
            const $koord = $('#filterKoordinatorluk');
            const $kom = $('#filterKomisyon');
            $koord.empty().append('<option value="">Seçiniz</option>').prop('disabled', !tesId);
            $kom.empty().append('<option value="">Seçiniz</option>').prop('disabled', true);

            if (tesId) {
                $.get('/Birimler/GetKoordinatorlukler?teskilatId=' + tesId, function(data) {
                    data.forEach(x => {
                        const opt = new Option(x.ad, x.koordinatorlukId);
                        if (selectedKId && x.koordinatorlukId == selectedKId) {
                            opt.selected = true;
                        }
                        $koord.append(opt);
                    });

                    if (selectedKId) {
                        $koord.trigger('change');
                    }
                });
            }
        }

        $('#filterKoordinatorluk').change(function() {
            const koordId = parseNullableInt($(this).val());
            const $kom = $('#filterKomisyon');
            $kom.empty().append('<option value="">Seçiniz</option>').prop('disabled', !koordId);

            selectedIlId = null;
            updateMapStatus(currentTeskilatId, koordId);

            if (koordId) {
                $.get('/Birimler/GetKomisyonlar?koordinatorlukId=' + koordId, function(data) {
                    data.forEach(x => $kom.append(new Option(x.ad, x.komisyonId)));
                });
            }

            loadKartlar();
        });

        $('#filterKomisyon').change(function() {
            const komId = $(this).val();
            if (komId) {
                window.location.href = '/Birimler/KomisyonDetay/' + komId;
            }
        });

        function loadKartlar() {
            const tesId = parseNullableInt($('#filterTeskilat').val());
            const koordId = parseNullableInt($('#filterKoordinatorluk').val());

            let url = '/Birimler/GetBirimKartlari?';
            if (koordId) {
                url += 'koordinatorlukId=' + koordId;
                if (selectedIlId) {
                    url += '&ilId=' + selectedIlId;
                }
            } else if (tesId) {
                url += 'teskilatId=' + tesId;
                if (selectedIlId) {
                    url += '&ilId=' + selectedIlId;
                }
            }

            $.get(url, function(data) {
                lastRenderedKartlar = data || [];
                renderKartlar(lastRenderedKartlar);
            });
        }

        function renderKartlar(kartlar) {
            const $container = $('#kartContainer');
            $container.empty();

            if (!kartlar || kartlar.length === 0) {
                $container.html('<div class="col-12 no-data-msg text-center p-5"><i class="bx bx-info-circle fs-1 d-block mb-3 text-muted"></i>Bir birim bulunamadı.</div>');
                $('#kartSayisi').text('0 birim');
                $('#btnGeriDon').addClass('d-none');
                return;
            }

            $('#kartSayisi').text(kartlar.length + ' birim');

            if (kartlar[0].tur === 'Komisyon') {
                $('#kartBaslik').html('<i class="bx bxs-group me-2 text-primary"></i>Komisyonlar');
                $('#btnGeriDon').removeClass('d-none');
            } else {
                $('#kartBaslik').html('<i class="bx bxs-grid-alt me-2 text-primary"></i>Koordinatörlükler');
                $('#btnGeriDon').addClass('d-none');
            }

            kartlar.forEach(k => {
                let displayedTitle = k.ad;

                if (currentTeskilatId == 1 && k.tur === 'Komisyon' && k.ilAdi) {
                    displayedTitle = `${k.ilAdi} ${k.ad}`;
                }

                const ilBadge = k.ilAdi ? `<div class="birim-il"><i class="bx bx-map-pin"></i> ${k.ilAdi}</div>` : '';
                const html = `
                    <div class="col">
                        <div class="card birim-card h-100" onclick="birimKartTiklandi('${k.tur}', ${k.id})">
                            <div class="card-body">
                                <div class="birim-ad">${displayedTitle}</div>
                                ${ilBadge}
                                <div class="stats-row">
                                    <div class="stat-item">
                                        <span class="stat-value">${k.personelSayisi}</span>
                                        <span class="stat-label">Personel</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-value" style="color: #ff9f43;">${k.gorevSayisi}</span>
                                        <span class="stat-label">Görev</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                $container.append(html);
            });
        }

        function birimKartTiklandi(tur, id) {
            if (tur === 'Komisyon') {
                window.location.href = '/Birimler/KomisyonDetay/' + id;
            } else if (tur === 'Koordinatorluk') {
                $('#filterKoordinatorluk').val(id).trigger('change');
            }
        }

        function findSingleCommissionForIl(ilId) {
            if (!Array.isArray(lastRenderedKartlar)) {
                return null;
            }

            const matches = lastRenderedKartlar.filter(k => k && k.tur === 'Komisyon' && k.ilId === ilId);
            return matches.length === 1 ? matches[0] : null;
        }

        function scrollToKartlar() {
            const scrollTarget = $("#kartBaslik").length ? $("#kartBaslik") : $("#kartContainer");
            $('html, body').animate({
                scrollTop: scrollTarget.offset().top - 100
            }, 500);
        }

        function geriDon() {
            $('#filterKoordinatorluk').val('').trigger('change');
        }
    </script>
}

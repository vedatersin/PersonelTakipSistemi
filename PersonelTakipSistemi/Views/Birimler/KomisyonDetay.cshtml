@model PersonelTakipSistemi.ViewModels.KomisyonDetayViewModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.KomisyonAd + " — Komisyon Detayı";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var coordinatorContext = string.Equals(currentController, "BirimYonetimi", StringComparison.OrdinalIgnoreCase);
    var backController = coordinatorContext ? "BirimYonetimi" : "Birimler";
    var backAction = coordinatorContext ? "KordinatorlukYonetimi" : "BirimListele";
    var backLabel = coordinatorContext ? "Birim Yönetimi" : "Birimleri Listele";
    var gorevReturnUrl = Url.Action("KomisyonDetay", "Birimler", new { id = Model.KomisyonId });
    const string gorevReturnLabel = "Komisyon Detayına Dön";
}

<style>
    .detail-header {
        background: linear-gradient(135deg, #696cff 0%, #8b8eff 100%);
        border-radius: 0.75rem;
        padding: 1.5rem 2rem;
        color: #fff;
        margin-bottom: 1.5rem;
    }
    .detail-header h4 { margin: 0; font-weight: 700; color: #fff; }
    .detail-header h4 i { color: #fff; }
    .detail-header .breadcrumb-item a { color: rgba(255,255,255,0.7); }
    .detail-header .breadcrumb-item span { color: rgba(255,255,255,0.78); }
    .detail-header .breadcrumb-item.active { color: #fff; }
    .detail-header .meta-info { font-size: 0.85rem; opacity: 0.85; margin-top: 0.5rem; }

    .stat-summary-card {
        border: none;
        border-radius: 0.5rem;
        text-align: center;
        padding: 1rem;
    }
    .stat-summary-card .stat-number { font-size: 2rem; font-weight: 700; }
    .stat-summary-card .stat-text { font-size: 0.8rem; color: #888; }

    .gorev-table .badge { font-size: 0.72rem; }
    .personel-table tr { cursor: pointer; }
    .personel-table .avatar-xs { width: 32px; height: 32px; }
    .personel-table .avatar-circle { width: 32px; height: 32px; border-radius: 50%; background: #696cff; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.75rem; }
    .personel-table img { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }
    
    /* Genişletilebilir Badge Stilleri */
    .extended-container { line-height: 2; margin-top: 5px; }
    .cursor-pointer { cursor: pointer; }
    .personel-table .badge { font-size: 0.7rem; padding: 0.4em 0.6em; }
    .personel-actions { display: inline-flex; gap: .5rem; white-space: nowrap; }
    .personel-action-btn { width: 44px; height: 44px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; padding: 0; border: 0; }
    .personel-action-btn i { font-size: 1.45rem; line-height: 1; }
    .personel-row-highlight { animation: personelHighlight 3s ease forwards; }
    @@keyframes personelHighlight {
        0%, 70% { background: rgba(3, 169, 244, .18); }
        100% { background: transparent; }
    }
    .role-chip { display: inline-flex; align-items: center; gap: .4rem; margin: .2rem; }
</style>

<!-- Header + Breadcrumb -->
<div class="detail-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a asp-controller="@backController" asp-action="@backAction"><i class="bx bx-arrow-back me-1"></i>@backLabel</a></li>
            @if (!string.IsNullOrEmpty(Model.TeskilatAd)) { <li class="breadcrumb-item"><span>@Model.TeskilatAd</span></li> }
            @if (!string.IsNullOrEmpty(Model.KoordinatorlukAd)) { <li class="breadcrumb-item"><span>@Model.KoordinatorlukAd</span></li> }
            <li class="breadcrumb-item active">@Model.KomisyonAd</li>
        </ol>
    </nav>
    <h4><i class="bx bxs-group me-2"></i>@Model.KomisyonAd</h4>
    <div class="meta-info">
        @if (!string.IsNullOrEmpty(Model.IlAd)) { <span><i class="bx bx-map-pin me-1"></i>@Model.IlAd</span> <span class="mx-2">|</span> }
        <span><i class="bx bx-user me-1"></i>@Model.Personeller.Count Personel</span>
        <span class="mx-2">|</span>
        <span><i class="bx bx-briefcase me-1"></i>@Model.Gorevler.Count Görev</span>
    </div>
</div>

<!-- Özet Kartları -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-summary-card">
            <div class="stat-number" style="color:#696cff;">@Model.Personeller.Count</div>
            <div class="stat-text">Toplam Personel</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-summary-card">
            <div class="stat-number" style="color:#ff9f43;">@Model.Gorevler.Count</div>
            <div class="stat-text">Toplam Görev</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-summary-card">
            <div class="stat-number" style="color:#71dd37;">@Model.KategoriDagilimi.Labels.Count</div>
            <div class="stat-text">Görev Kategorisi</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-summary-card">
            <div class="stat-number" style="color:#e74c3c;">@Model.DurumDagilimi.Labels.Count</div>
            <div class="stat-text">Durum Çeşidi</div>
        </div>
    </div>
</div>

<!-- Personel Listesi -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bx bxs-user-detail me-2" style="color:#696cff;"></i>Personeller</h6>
        <button type="button" class="btn btn-sm btn-primary" onclick="komisyonPersonelEkleAc()">
            <i class="bx bx-user-plus me-1"></i>Ekle
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
                <table class="table table-hover personel-table mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 50px;">FOTO</th>
                            <th>AD SOYAD</th>
                            <th>KULLANILAN YAZILIMLAR</th>
                            <th>UZMANLIK</th>
                            <th>GÖREV TÜRÜ</th>
                            <th>İŞ NİTELİĞİ</th>
                            <th>GÖREVLİ İL</th>
                            <th>KADRO YERİ</th>
                            <th class="text-end">İŞLEMLER</th>
                        </tr>
                    </thead>
                    <tbody id="komisyonPersonelBody">
                        @foreach (var p in Model.Personeller)
                        {
                            <tr data-personel-id="@p.PersonelId">
                                <td>
                                        @if (AvatarHelper.HasCustomPhoto(p.FotografYolu))
                                    {
                                        <img src="@p.FotografYolu" alt="@p.AdSoyad">
                                    }
                                    else
                                    {
                                        var initials = string.Join("", p.AdSoyad.Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString().ToUpper() : ""));
                                        <div class="avatar-circle">@initials</div>
                                    }
                                </td>
                                <td><span class="fw-bold">@p.AdSoyad</span></td>
                                
                                <!-- Yazılımlar -->
                                <td>
                                    @if(p.Yazilimlar.Any()) {
                                        @foreach(var item in p.Yazilimlar.Take(1)) { <span class="badge bg-label-primary me-1">@item</span> }
                                        @if(p.Yazilimlar.Count > 1) {
                                            <span class="badge bg-label-primary cursor-pointer show-more-btn" onclick="toggleContainer(this)">...</span>
                                            <div class="d-none extended-container">
                                                @foreach(var item in p.Yazilimlar.Skip(1)) { <span class="badge bg-label-primary me-1">@item</span> }
                                                <span class="badge bg-secondary cursor-pointer" onclick="toggleContainer(this)">X</span>
                                            </div>
                                        }
                                    } else { <span class="text-muted">-</span> }
                                </td>

                                <!-- Uzmanlıklar -->
                                <td>
                                    @if(p.Uzmanliklar.Any()) {
                                        @foreach(var item in p.Uzmanliklar.Take(1)) { <span class="badge bg-label-info me-1">@item</span> }
                                        @if(p.Uzmanliklar.Count > 1) {
                                            <span class="badge bg-label-info cursor-pointer show-more-btn" onclick="toggleContainer(this)">...</span>
                                            <div class="d-none extended-container">
                                                @foreach(var item in p.Uzmanliklar.Skip(1)) { <span class="badge bg-label-info me-1">@item</span> }
                                                <span class="badge bg-secondary cursor-pointer" onclick="toggleContainer(this)">X</span>
                                            </div>
                                        }
                                    } else { <span class="text-muted">-</span> }
                                </td>

                                <!-- Görev Türleri -->
                                <td>
                                    @if(p.GorevTurleri.Any()) {
                                        @foreach(var item in p.GorevTurleri.Take(1)) { <span class="badge bg-label-secondary me-1">@item</span> }
                                        @if(p.GorevTurleri.Count > 1) {
                                            <span class="badge bg-label-secondary cursor-pointer show-more-btn" onclick="toggleContainer(this)">...</span>
                                            <div class="d-none extended-container">
                                                @foreach(var item in p.GorevTurleri.Skip(1)) { <span class="badge bg-label-secondary me-1">@item</span> }
                                                <span class="badge bg-secondary cursor-pointer" onclick="toggleContainer(this)">X</span>
                                            </div>
                                        }
                                    } else { <span class="text-muted">-</span> }
                                </td>

                                <!-- İş Niteliği -->
                                <td>
                                    @if(p.IsNitelikleri.Any()) {
                                        @foreach(var item in p.IsNitelikleri.Take(1)) { <span class="badge bg-label-warning me-1">@item</span> }
                                        @if(p.IsNitelikleri.Count > 1) {
                                            <span class="badge bg-label-warning cursor-pointer show-more-btn" onclick="toggleContainer(this)">...</span>
                                            <div class="d-none extended-container">
                                                @foreach(var item in p.IsNitelikleri.Skip(1)) { <span class="badge bg-label-warning me-1">@item</span> }
                                                <span class="badge bg-secondary cursor-pointer" onclick="toggleContainer(this)">X</span>
                                            </div>
                                        }
                                    } else { <span class="text-muted">-</span> }
                                </td>

                                <td>@(p.Il ?? "—")</td>
                                <td>
                                    @if(!string.IsNullOrEmpty(p.KadroIl)) {
                                        <span>@p.KadroIl</span>
                                        @if(!string.IsNullOrEmpty(p.KadroIlce)) { <small class="text-muted"> / @p.KadroIlce</small> }
                                    } else { <span class="text-muted">-</span> }
                                </td>
                                <td class="text-end">
                                    <div class="personel-actions justify-content-end">
                                        <button type="button" class="btn btn-sm btn-info personel-action-btn text-white" title="Yetkilendir" data-bs-toggle="tooltip" onclick="event.stopPropagation(); komisyonYetkilendirAc(@p.PersonelId, '@p.AdSoyad.Replace("'", "\\'")')">
                                            <i class="bx bx-user-check"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger personel-action-btn" title="Komisyondan çıkar" data-bs-toggle="tooltip" onclick="event.stopPropagation(); komisyonPersonelCikar(@p.PersonelId)">
                                            <i class="bx bx-user-minus"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="komisyonPersonelEkleDrawer" aria-labelledby="komisyonPersonelEkleLabel" style="width: 560px;">
    <div class="offcanvas-header border-bottom">
        <h5 id="komisyonPersonelEkleLabel" class="offcanvas-title">Komisyona Personel Ekle</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
    </div>
    <div class="offcanvas-body">
        <div class="mb-3 p-3 bg-light rounded">
            <div class="small text-muted">Hedef Komisyon</div>
            <div class="fw-bold">@Model.KomisyonAd</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Personel Ara</label>
            <input type="text" class="form-control" id="komisyonPersonelAra" placeholder="Ad, soyad veya il ile ara">
        </div>
        <div class="mb-3">
            <label class="form-label">Personel</label>
            <select class="form-select" id="komisyonPersonelSelect" size="10"></select>
            <small class="text-muted">Admin tüm personelleri, koordinatörler kendi koordinatörlüğündeki personelleri görür.</small>
        </div>
    </div>
    <div class="offcanvas-footer p-3 border-top d-flex gap-2 bg-light">
        <button type="button" class="btn btn-label-secondary w-50" data-bs-dismiss="offcanvas">Kapat</button>
        <button type="button" class="btn btn-primary w-50" id="komisyonPersonelEkleBtn" onclick="komisyonPersonelEkle()">Ekle</button>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="komisyonYetkiDrawer" aria-labelledby="komisyonYetkiLabel" style="width: 620px;">
    <div class="offcanvas-header border-bottom">
        <h5 id="komisyonYetkiLabel" class="offcanvas-title">Yetkilendir</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
    </div>
    <div class="offcanvas-body">
        <input type="hidden" id="yetkiPersonelId" />
        <div class="mb-3 p-3 bg-light rounded">
            <div class="small text-muted">Personel</div>
            <div class="fw-bold" id="yetkiPersonelAd"></div>
        </div>
        <div class="mb-4">
            <label class="form-label">Mevcut Yetkiler</label>
            <div id="yetkiMevcutRoller" class="border rounded p-2 min-vh-0"></div>
        </div>
        <div class="row g-2">
            <div class="col-md-7">
                <label class="form-label">Yeni Yetki</label>
                <select class="form-select" id="yetkiRolSelect"></select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Kapsam</label>
                <select class="form-select" id="yetkiScopeSelect">
                    <option value="Komisyon">Bu komisyon</option>
                    <option value="Koordinatorluk">Koordinatörlük</option>
                </select>
            </div>
        </div>
    </div>
    <div class="offcanvas-footer p-3 border-top d-flex gap-2 bg-light">
        <button type="button" class="btn btn-label-secondary w-50" data-bs-dismiss="offcanvas">Kapat</button>
        <button type="button" class="btn btn-primary w-50" id="yetkiRolEkleBtn" onclick="komisyonRolEkle()">Yetki Ekle</button>
    </div>
</div>

<!-- Görev Listesi -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bx bxs-briefcase me-2" style="color:#ff9f43;"></i>Görevler</h6>
        <span class="badge bg-warning">@Model.Gorevler.Count görev</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Gorevler.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover gorev-table mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Başlık</th>
                            <th>Kategori</th>
                            <th>Durum</th>
                            <th>Başlangıç</th>
                            <th>Bitiş</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in Model.Gorevler)
                        {
                            <tr class="cursor-pointer" onclick="window.location.href='@Url.Action("Detay", "Gorevler", new { id = g.GorevId, returnUrl = gorevReturnUrl, returnLabel = gorevReturnLabel })'">
                                <td class="fw-semibold">@g.Baslik</td>
                                <td><span class="badge bg-label-info">@(g.Kategori ?? "—")</span></td>
                                <td><span class="badge" style="background-color: @(g.DurumRenk ?? "#6c757d"); color: #fff;">@g.Durum</span></td>
                                <td>@(g.BaslangicTarihi?.ToString("dd.MM.yyyy") ?? "—")</td>
                                <td>@(g.BitisTarihi?.ToString("dd.MM.yyyy") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-3"><i class="bx bx-task fs-3 d-block mb-2"></i>Bu komisyona henüz görev atanmamış.</div>
        }
    </div>
</div>

<!-- İstatistik Grafikleri -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><h6 class="mb-0"><i class="bx bx-pie-chart-alt me-2"></i>Görev Kategori Dağılımı</h6></div>
            <div class="card-body">
                @if (Model.KategoriDagilimi.Labels.Any())
                {
                    <canvas id="chartKategori" height="260"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-4">Görev verisi yok.</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><h6 class="mb-0"><i class="bx bx-bar-chart me-2"></i>Görev Durum Dağılımı</h6></div>
            <div class="card-body">
                @if (Model.DurumDagilimi.Labels.Any())
                {
                    <canvas id="chartDurum" height="260"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-4">Görev verisi yok.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const komisyonId = @Model.KomisyonId;
        const komisyonReturnUrl = encodeURIComponent('@gorevReturnUrl');
        const komisyonReturnLabel = encodeURIComponent('Komisyon Detayına Dön');
        let komisyonPersonelEkleDrawer = null;
        let komisyonYetkiDrawer = null;
        let komisyonPersonelSearchTimer = null;
        let komisyonHighlightPersonelIds = [];

        $(document).ready(function() {
            komisyonPersonelEkleDrawer = new bootstrap.Offcanvas(document.getElementById('komisyonPersonelEkleDrawer'));
            komisyonYetkiDrawer = new bootstrap.Offcanvas(document.getElementById('komisyonYetkiDrawer'));
            initKomisyonTooltips();
            loadKomisyonPersoneller();

            $('#komisyonPersonelAra').on('input', function() {
                clearTimeout(komisyonPersonelSearchTimer);
                komisyonPersonelSearchTimer = setTimeout(() => loadKomisyonEklePersoneller($(this).val()), 250);
            });
        });

        function escapeHtml(value) {
            return (value || '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function formatList(values) {
            return values && values.length ? escapeHtml(values.join(', ')) : '<span class="text-muted">-</span>';
        }

        function initKomisyonTooltips() {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
        }

        function loadKomisyonPersoneller() {
            $.get('/Birimler/GetKomisyonDetayPersoneller', { komisyonId }, function(data) {
                renderKomisyonPersoneller(data || []);
            });
        }

        function renderKomisyonPersoneller(personeller) {
            const $body = $('#komisyonPersonelBody');
            if (!$body.length) return;
            $body.empty();

            if (!personeller.length) {
                $body.html('<tr><td colspan="9" class="text-center text-muted py-4"><i class="bx bx-user-x fs-3 d-block mb-2"></i>Bu komisyona henüz personel atanmamış.</td></tr>');
                return;
            }

            personeller.forEach(p => {
                const names = (p.adSoyad || '').split(' ').filter(Boolean);
                const initials = ((names[0] || '?')[0] || '?') + ((names[names.length - 1] || '')[0] || '');
                const rowClass = komisyonHighlightPersonelIds.includes(p.personelId) ? 'personel-row-highlight' : '';
                const href = `/Personel/Detay/${p.personelId}?returnUrl=${komisyonReturnUrl}&returnLabel=${komisyonReturnLabel}`;
                const avatar = p.fotografYolu
                    ? `<img src="${escapeHtml(p.fotografYolu)}" alt="${escapeHtml(p.adSoyad)}">`
                    : `<div class="avatar-circle">${escapeHtml(initials.toUpperCase())}</div>`;

                $body.append(`
                    <tr class="${rowClass}" data-personel-id="${p.personelId}">
                        <td onclick="window.location.href='${href}'">${avatar}</td>
                        <td onclick="window.location.href='${href}'"><span class="fw-bold">${escapeHtml(p.adSoyad)}</span></td>
                        <td onclick="window.location.href='${href}'">${formatList(p.yazilimlar)}</td>
                        <td onclick="window.location.href='${href}'">${formatList(p.uzmanliklar)}</td>
                        <td onclick="window.location.href='${href}'">${formatList(p.gorevTurleri)}</td>
                        <td onclick="window.location.href='${href}'">${formatList(p.isNitelikleri)}</td>
                        <td onclick="window.location.href='${href}'">${escapeHtml(p.gorevliIl || '—')}</td>
                        <td onclick="window.location.href='${href}'">${escapeHtml(p.kadroYeri || '-')}</td>
                        <td class="text-end">
                            <div class="personel-actions justify-content-end">
                                <button type="button" class="btn btn-sm btn-info personel-action-btn text-white" title="Yetkilendir" data-bs-toggle="tooltip" onclick="komisyonYetkilendirAc(${p.personelId}, '${escapeHtml(p.adSoyad)}')">
                                    <i class="bx bx-user-check"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-danger personel-action-btn" title="Komisyondan çıkar" data-bs-toggle="tooltip" onclick="komisyonPersonelCikar(${p.personelId})">
                                    <i class="bx bx-user-minus"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `);
            });

            initKomisyonTooltips();

            if (komisyonHighlightPersonelIds.length) {
                setTimeout(() => {
                    $('.personel-row-highlight').removeClass('personel-row-highlight');
                    komisyonHighlightPersonelIds = [];
                }, 3000);
            }
        }

        function komisyonPersonelEkleAc() {
            $('#komisyonPersonelAra').val('');
            $('#komisyonPersonelSelect').empty().append('<option>Personeller yükleniyor...</option>');
            loadKomisyonEklePersoneller('');
            komisyonPersonelEkleDrawer.show();
        }

        function loadKomisyonEklePersoneller(query) {
            $.get('/Birimler/GetKomisyonEklePersoneller', { komisyonId, q: query || '' }, function(data) {
                const $select = $('#komisyonPersonelSelect');
                $select.empty();
                if (!data || !data.length) {
                    $select.append('<option value="">Uygun personel bulunamadı</option>');
                    return;
                }

                data.forEach(p => {
                    const label = p.adSoyad + (p.il ? ' - ' + p.il : '');
                    $select.append(new Option(label, p.personelId));
                });
            }).fail(function() {
                $('#komisyonPersonelSelect').empty().append('<option value="">Personeller yüklenemedi</option>');
            });
        }

        function komisyonPersonelEkle() {
            const personelId = parseInt($('#komisyonPersonelSelect').val(), 10);
            if (!personelId) {
                Swal.fire('Personel Seçiniz', 'Eklemek için bir personel seçiniz.', 'warning');
                return;
            }

            $('#komisyonPersonelEkleBtn').prop('disabled', true);
            $.post('/Birimler/KomisyonDetayPersonelEkle', { personelId, komisyonId })
                .done(function() {
                    komisyonHighlightPersonelIds = [personelId];
                    komisyonPersonelEkleDrawer.hide();
                    loadKomisyonPersoneller();
                    Swal.fire({ icon: 'success', title: 'Personel eklendi', toast: true, position: 'top-end', timer: 1800, showConfirmButton: false });
                })
                .fail(function(xhr) {
                    Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Personel eklenemedi.', 'error');
                })
                .always(function() {
                    $('#komisyonPersonelEkleBtn').prop('disabled', false);
                });
        }

        function komisyonPersonelCikar(personelId) {
            Swal.fire({
                title: 'Personel komisyondan çıkarılsın mı?',
                text: 'Kayıt koordinatörlükte kalır, sadece komisyondan çıkarılır.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Çıkar',
                cancelButtonText: 'İptal'
            }).then(result => {
                if (!result.isConfirmed) return;

                $.post('/Birimler/KomisyonDetayPersonelCikar', { personelId, komisyonId })
                    .done(function() {
                        loadKomisyonPersoneller();
                        Swal.fire({ icon: 'success', title: 'Çıkarıldı', toast: true, position: 'top-end', timer: 1800, showConfirmButton: false });
                    })
                    .fail(function(xhr) {
                        Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Personel çıkarılamadı.', 'error');
                    });
            });
        }

        function komisyonYetkilendirAc(personelId, adSoyad) {
            $('#yetkiPersonelId').val(personelId);
            $('#yetkiPersonelAd').text(adSoyad);
            $('#yetkiMevcutRoller').html('<span class="text-muted">Yetkiler yükleniyor...</span>');
            $('#yetkiRolSelect').empty();

            $.get('/Birimler/GetKomisyonPersonelYetkiData', { personelId, komisyonId }, function(data) {
                renderYetkiData(data);
                komisyonYetkiDrawer.show();
            }).fail(function(xhr) {
                Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Yetki bilgileri yüklenemedi.', 'error');
            });
        }

        function renderYetkiData(data) {
            const $roles = $('#yetkiMevcutRoller');
            $roles.empty();

            if (!data.roles || !data.roles.length) {
                $roles.html('<span class="text-muted">Bu kapsamda tanımlı yetki bulunmuyor.</span>');
            } else {
                data.roles.forEach(role => {
                    $roles.append(`
                        <span class="badge bg-label-primary role-chip">
                            ${escapeHtml(role.rolAd)} <small>${escapeHtml(role.contextAd)}</small>
                            <button type="button" class="btn-close btn-close-sm ms-1" aria-label="Sil" onclick="komisyonRolSil(${role.assignmentId})"></button>
                        </span>
                    `);
                });
            }

            const $select = $('#yetkiRolSelect');
            $select.empty().append('<option value="">Yetki seçiniz</option>');
            (data.roleOptions || []).forEach(role => $select.append(new Option(role.ad, role.id)));
        }

        function komisyonRolEkle() {
            const personelId = parseInt($('#yetkiPersonelId').val(), 10);
            const kurumsalRolId = parseInt($('#yetkiRolSelect').val(), 10);
            const scope = $('#yetkiScopeSelect').val();

            if (!personelId || !kurumsalRolId) {
                Swal.fire('Eksik Bilgi', 'Eklemek için yetki seçiniz.', 'warning');
                return;
            }

            $('#yetkiRolEkleBtn').prop('disabled', true);
            $.post('/Birimler/KomisyonDetayRolEkle', { personelId, kurumsalRolId, komisyonId, scope })
                .done(function(response) {
                    if (response && response.warning) {
                        Swal.fire('Uyarı', response.warning, 'warning');
                        return;
                    }
                    komisyonYetkilendirAc(personelId, $('#yetkiPersonelAd').text());
                    Swal.fire({ icon: 'success', title: 'Yetki eklendi', toast: true, position: 'top-end', timer: 1600, showConfirmButton: false });
                })
                .fail(function(xhr) {
                    Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Yetki eklenemedi.', 'error');
                })
                .always(function() {
                    $('#yetkiRolEkleBtn').prop('disabled', false);
                });
        }

        function komisyonRolSil(assignmentId) {
            $.post('/Birimler/KomisyonDetayRolSil', { assignmentId, komisyonId })
                .done(function() {
                    const personelId = parseInt($('#yetkiPersonelId').val(), 10);
                    komisyonYetkilendirAc(personelId, $('#yetkiPersonelAd').text());
                })
                .fail(function(xhr) {
                    Swal.fire('Hata', xhr.responseJSON?.message || xhr.responseText || 'Yetki silinemedi.', 'error');
                });
        }

        function toggleContainer(element) {
            if (event) event.stopPropagation();
            
            if (element.classList.contains('show-more-btn')) {
                var container = element.nextElementSibling;
                if(container) {
                    element.classList.add('d-none');
                    container.classList.remove('d-none');
                }
            } else {
                var container = element.parentElement;
                var showBtn = container.previousElementSibling;
                container.classList.add('d-none');
                if(showBtn) {
                    showBtn.classList.remove('d-none');
                }
            }
        }

        @if (Model.KategoriDagilimi.Labels.Any())
        {
            <text>
            new Chart(document.getElementById('chartKategori'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.KategoriDagilimi.Labels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.KategoriDagilimi.Data)),
                        backgroundColor: @Html.Raw(Json.Serialize(Model.KategoriDagilimi.Colors.Take(Model.KategoriDagilimi.Labels.Count)))
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } }
                }
            });
            </text>
        }

        @if (Model.DurumDagilimi.Labels.Any())
        {
            <text>
            new Chart(document.getElementById('chartDurum'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.DurumDagilimi.Labels)),
                    datasets: [{
                        label: 'Görev Sayısı',
                        data: @Html.Raw(Json.Serialize(Model.DurumDagilimi.Data)),
                        backgroundColor: @Html.Raw(Json.Serialize(Model.DurumDagilimi.Colors))
                    }]
                },
                options: {
                    responsive: true,
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                    plugins: { legend: { display: false } }
                }
            });
            </text>
        }
    </script>
}

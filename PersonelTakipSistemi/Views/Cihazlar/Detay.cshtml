@model PersonelTakipSistemi.ViewModels.CihazDetayViewModel
@{
    ViewData["Title"] = "Cihaz Detayı";
    var returnAction = (string?)ViewBag.ReturnAction ?? "BenimCihazlarim";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-3">
        <a asp-action="@returnAction" class="btn btn-label-secondary"><i class="bx bx-arrow-back me-1"></i> Geri Dön</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-lg-12 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@Model.CihazTuru - @Model.Marka</h5>
                    <div class="d-flex gap-2">
                        @if (Model.OnayYetkisiVarMi)
                        {
                            <form asp-action="OnaylaDetay" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cihazId" value="@Model.CihazId" />
                                <input type="hidden" name="returnAction" value="@returnAction" />
                                <button type="submit" class="btn btn-warning">Onayla</button>
                            </form>
                        }
                        @if (Model.DuzenlemeYetkisiVarMi)
                        {
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#duzenleModal">Düzenle</button>
                        }
                        @if (Model.DevirYetkisiVarMi)
                        {
                            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#devirModal">Cihazı Devret</button>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="SilDetay" method="post" class="d-inline" onsubmit="return confirm('Bu cihaz kaydını silmek istediğinize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cihazId" value="@Model.CihazId" />
                                <input type="hidden" name="returnAction" value="@returnAction" />
                                <button type="submit" class="btn btn-danger">Sil</button>
                            </form>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label text-muted">Cihaz Sahibi</label><div class="fw-semibold">@Model.SahipAdSoyad</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Koordinatörlük</label><div class="fw-semibold">@Model.KoordinatorlukAd</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Model</label><div class="fw-semibold">@Model.Model</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Seri No</label><div class="fw-semibold">@Model.SeriNo</div></div>
                        <div class="col-md-12"><label class="form-label text-muted">Özellikler</label><div class="border rounded bg-light p-3">@Model.Ozellikler</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">@Model.KayitTarihiBasligi</label><div class="fw-semibold">@Model.GosterilecekKayitTarihi.ToString("dd.MM.yyyy HH:mm")</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Durum</label><div><span class="badge @(Model.OnayDurumu == PersonelTakipSistemi.Models.CihazOnayDurumu.Onaylandi ? "bg-label-success" : "bg-label-warning")">@(Model.OnayDurumu == PersonelTakipSistemi.Models.CihazOnayDurumu.Onaylandi ? "Onaylı" : "Onay Bekliyor")</span></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.HareketlerGorunsunMu)
    {
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Cihaz Hareketliliği</h5></div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>İşlem</th>
                            <th>İşlem Yapan</th>
                            <th>Detay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hareket in Model.Hareketler)
                        {
                            <tr>
                                <td>@hareket.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@hareket.HareketTuru</td>
                                <td>
                                    <span class="@(hareket.IslemYapanCizili ? "text-decoration-line-through" : "")">@hareket.IslemYapan</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(hareket.OncekiSahip))
                                    {
                                        <span class="me-2">
                                            Önceki:
                                            <span class="@(hareket.OncekiSahipCizili ? "text-decoration-line-through" : "")">@hareket.OncekiSahip</span>
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hareket.YeniSahip))
                                    {
                                        <span class="me-2">
                                            Yeni:
                                            <span class="@(hareket.YeniSahipCizili ? "text-decoration-line-through" : "")">@hareket.YeniSahip</span>
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hareket.Aciklama))
                                    {
                                        <span>@hareket.Aciklama</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hareket.DurumNotu))
                                    {
                                        <span> | Not: @hareket.DurumNotu</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (Model.DuzenlemeYetkisiVarMi)
{
    <div class="modal fade" id="duzenleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Guncelle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CihazId" value="@Model.DuzenleFormu.CihazId" />
                    <input type="hidden" name="returnAction" value="@returnAction" />
                    <div class="modal-header">
                        <h5 class="modal-title">@(Model.DuzenlemeOnayGerekliMi ? "Düzenlemeyi Onaya Gönder" : "Cihazı Düzenle / Normalize Et")</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Cihaz Türü</label>
                                <select name="CihazTuruId" class="form-select searchable-select" id="duzenleCihazTuru">
                                    <option value="">Seçiniz</option>
                                    @foreach (var item in Model.CihazTurleri)
                                    {
                                        if (item.Id == Model.DuzenleFormu.CihazTuruId)
                                        {
                                            <option value="@item.Id" selected>@item.Ad</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Ad</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-12 @(Model.DuzenleFormu.CihazTuruId == 999 ? "" : "d-none")" id="duzenleDigerTurWrap">
                                <label class="form-label">Diğer Cihaz Türü</label>
                                <input name="DigerCihazTuruAd" value="@Model.DuzenleFormu.DigerCihazTuruAd" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Marka</label>
                                <select name="CihazMarkaId" class="form-select searchable-select" id="duzenleMarka">
                                    <option value="">Seçiniz</option>
                                    @foreach (var item in Model.Markalar)
                                    {
                                        if (item.Id == Model.DuzenleFormu.CihazMarkaId)
                                        {
                                            <option value="@item.Id" selected>@item.Ad</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Ad</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-12 @(Model.DuzenleFormu.CihazMarkaId == 99999 ? "" : "d-none")" id="duzenleDigerMarkaWrap">
                                <label class="form-label">Diğer Marka</label>
                                <input name="DigerMarkaAd" value="@Model.DuzenleFormu.DigerMarkaAd" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Model</label>
                                <input name="Model" value="@Model.DuzenleFormu.Model" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Özellikler</label>
                                <input name="Ozellikler" value="@Model.DuzenleFormu.Ozellikler" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Seri No</label>
                                <input name="SeriNo" value="@Model.DuzenleFormu.SeriNo" class="form-control" />
                            </div>
                            <div class="col-12">
                                <div class="alert alert-info mb-0">
                                    @(Model.DuzenlemeOnayGerekliMi
                                        ? "Bu düzenleme onaya gönderilir. Cihaz tekrar admin veya koordinatör onayı bekler."
                                        : "Bu düzenleme hareket geçmişine yazılmaz; sistem logunda görünür.")
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">@(Model.DuzenlemeOnayGerekliMi ? "Onaya Gönder" : "Kaydet")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.DevirYetkisiVarMi)
{
    <div class="modal fade" id="devirModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Devret" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CihazId" value="@Model.DevirFormu.CihazId" />
                    <input type="hidden" name="returnAction" value="@returnAction" />
                    <div class="modal-header">
                        <h5 class="modal-title">Cihazı Devret</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Mevcut Sahip</label>
                            <input class="form-control" value="@Model.SahipAdSoyad" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Devredilecek Personel</label>
                            <select name="YeniSahipPersonelId" class="form-select searchable-select" id="devirYeniSahipPersonelId">
                                <option value="">Seçiniz</option>
                                @foreach (var item in Model.DevredilebilirPersoneller)
                                {
                                    <option value="@item.Id">@item.Ad</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Devir Notu</label>
                            <textarea name="DevirNotu" class="form-control" rows="3">@Model.DevirFormu.DevirNotu</textarea>
                        </div>
                        <div>
                            <label class="form-label">Cihaz Notu</label>
                            <textarea name="CihazDurumNotu" class="form-control" rows="3">@Model.DevirFormu.CihazDurumNotu</textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-success">Devret</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function initDetailSearchableSelects() {
            if (typeof window.jQuery === 'undefined' || typeof window.jQuery.fn.select2 === 'undefined') return;
            const $ = window.jQuery;
            $('.searchable-select').each(function () {
                const $el = $(this);
                if ($el.hasClass('select2-hidden-accessible')) return;
                const modalParent = $el.closest('.modal');
                $el.select2({
                    theme: 'bootstrap-5',
                    width: '100%',
                    placeholder: 'Seçiniz',
                    allowClear: true,
                    dropdownParent: modalParent.length ? modalParent : undefined
                });
            });
        }

        async function loadBrandsForEdit(typeId, selectedBrandId) {
            const brandSelect = document.getElementById('duzenleMarka');
            if (!brandSelect) return;
            brandSelect.innerHTML = '<option value="">Seçiniz</option>';
            if (!typeId) return;

            const res = await fetch(`/Cihazlar/GetBrands?cihazTuruId=${typeId}`);
            const data = await res.json();
            data.forEach(item => {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = item.ad;
                if (selectedBrandId && parseInt(selectedBrandId) === item.id) {
                    option.selected = true;
                }
                brandSelect.appendChild(option);
            });
            if (typeof window.jQuery !== 'undefined') {
                window.jQuery(brandSelect).trigger('change');
            }
            toggleOtherEditFields();
        }

        function toggleOtherEditFields() {
            const typeSelect = document.getElementById('duzenleCihazTuru');
            const brandSelect = document.getElementById('duzenleMarka');
            document.getElementById('duzenleDigerTurWrap')?.classList.toggle('d-none', typeSelect?.value !== '999');
            document.getElementById('duzenleDigerMarkaWrap')?.classList.toggle('d-none', brandSelect?.value !== '99999');
        }

        document.getElementById('duzenleCihazTuru')?.addEventListener('change', async function () {
            await loadBrandsForEdit(this.value, null);
        });

        document.getElementById('duzenleMarka')?.addEventListener('change', toggleOtherEditFields);
        if (typeof window.jQuery !== 'undefined') {
            window.jQuery('#duzenleCihazTuru').on('select2:select select2:clear', async function () {
                await loadBrandsForEdit(this.value, null);
            });
            window.jQuery('#duzenleMarka').on('select2:select select2:clear', toggleOtherEditFields);
        }

        initDetailSearchableSelects();
        loadBrandsForEdit(document.getElementById('duzenleCihazTuru')?.value, document.getElementById('duzenleMarka')?.value);
        document.getElementById('duzenleModal')?.addEventListener('shown.bs.modal', function () {
            toggleOtherEditFields();
        });
    </script>
}


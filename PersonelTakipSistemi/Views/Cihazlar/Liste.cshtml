@model PersonelTakipSistemi.ViewModels.CihazListePageViewModel
@{
    ViewData["Title"] = Model.Baslik;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Yaz&#305;l&#305;m Lisanslar&#305; ve Cihazlar /</span> @Model.Baslik</h4>
        @if (Model.CihazEklemeYetkisiVarMi)
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#cihazEkleModal">+ Ekle</button>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                @if (Model.Koordinatorlukler.Any())
                {
                    <div class="col-md-3">
                        <label class="form-label">Koordinat&ouml;rl&uuml;k</label>
                        <select asp-for="Filter.KoordinatorlukId" class="form-select searchable-select">
                            <option value="">T&uuml;m&uuml;</option>
                            @foreach (var item in Model.Koordinatorlukler)
                            {
                                <option value="@item.Id">@item.Ad</option>
                            }
                        </select>
                    </div>
                }
                @if (Model.Personeller.Any())
                {
                    <div class="col-md-3">
                        <label class="form-label">Personel</label>
                        <select asp-for="Filter.PersonelId" class="form-select searchable-select">
                            <option value="">T&uuml;m&uuml;</option>
                            @foreach (var item in Model.Personeller)
                            {
                                <option value="@item.Id">@item.Ad</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-md-3">
                    <label class="form-label">Cihaz T&uuml;r&uuml;</label>
                    <select asp-for="Filter.CihazTuruId" class="form-select searchable-select" id="filterCihazTuru">
                        <option value="">T&uuml;m&uuml;</option>
                        @foreach (var item in Model.CihazTurleri)
                        {
                            <option value="@item.Id">@item.Ad</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Marka</label>
                    <select asp-for="Filter.CihazMarkaId" class="form-select searchable-select" id="filterMarka">
                        <option value="">T&uuml;m&uuml;</option>
                        @foreach (var item in Model.Markalar)
                        {
                            <option value="@item.Id">@item.Ad</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Model</label>
                    <input asp-for="Filter.ModelAra" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">&Ouml;zellik</label>
                    <input asp-for="Filter.OzellikAra" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Seri No</label>
                    <input asp-for="Filter.SeriNoAra" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label d-block">Kayıt Yaşı</label>
                    <input asp-for="Filter.YasSliderDegeri" type="hidden" id="yasSliderDegeri" />
                    <div class="kayit-yasi-slider-wrap">
                        <input type="range"
                               id="kayitYasiSlider"
                               min="0"
                               max="6"
                               step="1"
                               class="kayit-yasi-slider"
                               value="@(Model.Filter.YasSliderDegeri >= 0 && Model.Filter.YasSliderDegeri <= 6 ? Model.Filter.YasSliderDegeri : 0)"
                               data-initial="@Model.Filter.YasSliderDegeri" />
                        <div id="kayitYasiAktifEtiket" class="kayit-yasi-aktif">Tümü</div>
                    </div>
                </div>
                @if (Model.OnayYetkisiVarMi)
                {
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="Filter.SadeceOnayBekleyenler" class="form-check-input" />
                            <label asp-for="Filter.SadeceOnayBekleyenler" class="form-check-label">Sadece onay bekleyenler</label>
                        </div>
                    </div>
                }
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Filtrele</button>
                    <a asp-action="@(Model.PersonelGorunumuMu ? "BenimCihazlarim" : "Liste")" class="btn btn-label-secondary">Temizle</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>T&uuml;r</th>
                        <th>Marka</th>
                        <th>Model</th>
                        <th>&Ouml;zellikler</th>
                        <th>Sahip</th>
                        <th>Koordinat&ouml;rl&uuml;k</th>
                        <th>Koordinat&ouml;r Onay&#305;</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Cihazlar.Any())
                    {
                        @foreach (var item in Model.Cihazlar)
                        {
                            <tr id="cihaz-row-@item.CihazId">
                                <td>@item.CihazTuru</td>
                                <td>@item.Marka</td>
                                <td>@item.Model</td>
                                <td>@item.Ozellikler</td>
                                <td>@item.SahipAdSoyad</td>
                                <td>@item.KoordinatorlukAd</td>
                                <td>
                                    <span class="badge @(item.OnayDurumu == PersonelTakipSistemi.Models.CihazOnayDurumu.Onaylandi ? "bg-label-success" : "bg-label-warning")">
                                        @(item.OnayDurumu == PersonelTakipSistemi.Models.CihazOnayDurumu.Onaylandi ? "Onayland\u0131" : "Onay Bekliyor")
                                    </span>
                                </td>
                                <td class="text-nowrap">
                                    <a asp-action="Detay" asp-route-id="@item.CihazId" class="btn btn-sm btn-label-primary">Detay</a>
                                    @if (Model.OnayYetkisiVarMi && item.OnayDurumu == PersonelTakipSistemi.Models.CihazOnayDurumu.Beklemede)
                                    {
                                        <form asp-action="Onayla" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="cihazId" value="@item.CihazId" />
                                            <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Cihaz kayd&#305; bulunamad&#305;.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.CihazEklemeYetkisiVarMi)
{
    <div class="modal fade" id="cihazEkleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Ekle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnAction" value="@(Model.PersonelGorunumuMu ? "BenimCihazlarim" : "Liste")" />
                    <div class="modal-header">
                        <h5 class="modal-title">Cihaz Ekle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            @if (Model.EklemeIcinPersoneller.Any() && !Model.PersonelGorunumuMu)
                            {
                                <div class="col-md-6">
                                    <label class="form-label">Cihaz Sahibi</label>
                                    <select asp-for="YeniCihaz.SahipPersonelId" class="form-select searchable-select">
                                        <option value="">Se&ccedil;iniz</option>
                                        @foreach (var item in Model.EklemeIcinPersoneller)
                                        {
                                            <option value="@item.Id">@item.Ad</option>
                                        }
                                    </select>
                                </div>
                            }
                            <div class="col-md-6">
                                <label class="form-label">Cihaz T&uuml;r&uuml;</label>
                                <select asp-for="YeniCihaz.CihazTuruId" class="form-select searchable-select" id="eklemeCihazTuru">
                                    <option value="">Se&ccedil;iniz</option>
                                    @foreach (var item in Model.EklemeIcinCihazTurleri)
                                    {
                                        <option value="@item.Id">@item.Ad</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 d-none" id="digerTurWrap">
                                <label class="form-label">Di&#287;er Cihaz T&uuml;r&uuml;</label>
                                <input asp-for="YeniCihaz.DigerCihazTuruAd" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Marka</label>
                                <select asp-for="YeniCihaz.CihazMarkaId" class="form-select searchable-select" id="eklemeMarka">
                                    <option value="">&Ouml;nce cihaz t&uuml;r&uuml; se&ccedil;iniz</option>
                                </select>
                            </div>
                            <div class="col-md-6 d-none" id="digerMarkaWrap">
                                <label class="form-label">Di&#287;er Marka</label>
                                <input asp-for="YeniCihaz.DigerMarkaAd" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Model</label>
                                <input asp-for="YeniCihaz.Model" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">&Ouml;zellikler</label>
                                <input asp-for="YeniCihaz.Ozellikler" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Seri No</label>
                                <input asp-for="YeniCihaz.SeriNo" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">&#304;ptal</button>
                        <button type="submit" class="btn btn-primary">@Html.Raw(Model.PersonelGorunumuMu ? "Onaya G&ouml;nder" : "G&ouml;nder")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        .kayit-yasi-slider-wrap {
            --slider-fill: 0%;
        }

        .kayit-yasi-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 10px;
            border-radius: 999px;
            outline: none;
            background: linear-gradient(to right, #696cff 0%, #696cff var(--slider-fill), #d9dee3 var(--slider-fill), #d9dee3 100%);
        }

        .kayit-yasi-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid #696cff;
            box-shadow: 0 1px 4px rgba(67, 89, 113, 0.25);
            cursor: pointer;
            margin-top: -4px;
        }

        .kayit-yasi-slider::-moz-range-track {
            height: 10px;
            border-radius: 999px;
            background: #d9dee3;
        }

        .kayit-yasi-slider::-moz-range-progress {
            height: 10px;
            border-radius: 999px;
            background: #696cff;
        }

        .kayit-yasi-slider::-moz-range-thumb {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid #696cff;
            box-shadow: 0 1px 4px rgba(67, 89, 113, 0.25);
            cursor: pointer;
        }

        .kayit-yasi-slider-all::-webkit-slider-thumb {
            border-color: #d9dee3;
        }

        .kayit-yasi-slider-all::-moz-range-thumb {
            border-color: #d9dee3;
        }

        .kayit-yasi-aktif {
            margin-top: 0.65rem;
            min-height: 1.25rem;
            color: #566a7f;
            font-size: 0.8125rem;
            font-weight: 600;
            text-align: center;
        }

        @@keyframes highlightBlue {
            0% { background-color: rgba(13, 110, 253, 0.32); }
            100% { background-color: transparent; }
        }

        .highlight-new {
            animation: highlightBlue 3s ease-out;
        }
    </style>
}

@section Scripts {
    <script>
        const yeniCihazId = '@TempData["NewCihazId"]';
        const yasSliderInput = document.getElementById('kayitYasiSlider');
        const yasSliderHiddenInput = document.getElementById('yasSliderDegeri');
        const yasSliderAktifEtiket = document.getElementById('kayitYasiAktifEtiket');
        const cihazEkleModalElement = document.getElementById('cihazEkleModal');

        const yasSliderEtiketleri = [
            '1 y\u0131ldan az',
            '1 y\u0131ldan fazla',
            '2 y\u0131ldan fazla',
            '3 y\u0131ldan fazla',
            '4 y\u0131ldan fazla',
            '5 y\u0131ldan fazla'
        ];

        function updateYasSliderUI(isAllState = false) {
            if (!yasSliderInput || !yasSliderHiddenInput || !yasSliderAktifEtiket) return;

            const numericValue = Number(yasSliderInput.value || 0);
            const maxValue = Number(yasSliderInput.max || 6);
            const fillPercent = maxValue > 0 ? (numericValue / maxValue) * 100 : 0;

            yasSliderInput.style.setProperty('--slider-fill', `${fillPercent}%`);

            if (isAllState) {
                yasSliderAktifEtiket.textContent = 'T\u00fcm\u00fc';
                return;
            }

            yasSliderAktifEtiket.textContent = yasSliderEtiketleri[numericValue - 1] || yasSliderEtiketleri[0];
        }

        if (yasSliderInput && yasSliderHiddenInput) {
            const initialHiddenValue = Number(yasSliderInput.dataset.initial ?? yasSliderHiddenInput.value ?? -1);
            const isAllState = initialHiddenValue < 0;

            if (isAllState) {
                yasSliderHiddenInput.value = -1;
                yasSliderInput.value = 0;
                updateYasSliderUI(true);
            } else {
                yasSliderHiddenInput.value = initialHiddenValue;
                yasSliderInput.value = initialHiddenValue;
                updateYasSliderUI(false);
            }

            yasSliderInput.addEventListener('input', function () {
                const isAll = Number(yasSliderInput.value) === 0;
                yasSliderHiddenInput.value = isAll ? -1 : yasSliderInput.value;
                updateYasSliderUI(isAll);
            });

            yasSliderInput.addEventListener('change', function () {
                const isAll = Number(yasSliderInput.value) === 0;
                yasSliderHiddenInput.value = isAll ? -1 : yasSliderInput.value;
                updateYasSliderUI(isAll);
            });
        }

        function initSearchableSelects() {
            if (typeof window.jQuery === 'undefined' || typeof window.jQuery.fn.select2 === 'undefined') return;

            const $ = window.jQuery;
            $('.searchable-select').each(function () {
                const $el = $(this);
                if ($el.hasClass('select2-hidden-accessible')) {
                    return;
                }

                const inCihazEkleModal = cihazEkleModalElement && cihazEkleModalElement.contains(this);
                $el.select2({
                    theme: 'bootstrap-5',
                    width: '100%',
                    placeholder: 'Se\u00e7iniz',
                    allowClear: true,
                    dropdownParent: inCihazEkleModal ? $(cihazEkleModalElement) : undefined
                });
            });
        }

        initSearchableSelects();

        function getBrandDefaultOptionLabel(brandSelectId) {
            return brandSelectId === 'filterMarka' ? 'T\u00fcm\u00fc' : 'Se\u00e7iniz';
        }

        function refreshSelect2(selectEl) {
            if (typeof window.jQuery === 'undefined') return;
            window.jQuery(selectEl).trigger('change');
        }

        async function loadBrands(typeSelectId, brandSelectId) {
            const typeSelect = document.getElementById(typeSelectId);
            const brandSelect = document.getElementById(brandSelectId);
            if (!typeSelect || !brandSelect) return;

            const typeId = typeSelect.value;
            const defaultOptionLabel = getBrandDefaultOptionLabel(brandSelectId);
            const previouslySelectedBrand = brandSelect.value;

            brandSelect.innerHTML = `<option value="">${defaultOptionLabel}</option>`;

            if (!typeId) {
                refreshSelect2(brandSelect);
                return;
            }

            try {
                const res = await fetch(`/Cihazlar/GetBrands?cihazTuruId=${encodeURIComponent(typeId)}`);
                if (!res.ok) {
                    refreshSelect2(brandSelect);
                    return;
                }

                const data = await res.json();
                data.forEach(item => {
                    const option = document.createElement('option');
                    option.value = String(item.id);
                    option.textContent = item.ad;
                    brandSelect.appendChild(option);
                });

                const matched = Array.from(brandSelect.options).some(o => o.value === previouslySelectedBrand);
                brandSelect.value = matched ? previouslySelectedBrand : '';
                refreshSelect2(brandSelect);
            } catch {
                refreshSelect2(brandSelect);
            }
        }

        async function loadDeviceTypesIntoModal() {
            const eklemeTur = document.getElementById('eklemeCihazTuru');
            if (!eklemeTur || eklemeTur.options.length > 1) return;

            try {
                const res = await fetch('/Cihazlar/GetTypes');
                if (!res.ok) return;

                const data = await res.json();
                if (!Array.isArray(data) || data.length === 0) return;

                eklemeTur.innerHTML = '<option value="">Seçiniz</option>';
                data.forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = String(item.id);
                    opt.textContent = item.ad;
                    eklemeTur.appendChild(opt);
                });

                refreshSelect2(eklemeTur);
            } catch {
            }
        }

        function toggleOtherFields(typeSelectId, brandSelectId, typeWrapId, brandWrapId) {
            const typeText = document.getElementById(typeSelectId)?.selectedOptions[0]?.text || '';
            const brandText = document.getElementById(brandSelectId)?.selectedOptions[0]?.text || '';
            document.getElementById(typeWrapId)?.classList.toggle('d-none', typeText !== 'Di\u011fer');
            document.getElementById(brandWrapId)?.classList.toggle('d-none', brandText !== 'Di\u011fer');
        }

        const onFilterTypeChanged = async () => {
            await loadBrands('filterCihazTuru', 'filterMarka');
        };

        document.getElementById('filterCihazTuru')?.addEventListener('change', onFilterTypeChanged);
        if (typeof window.jQuery !== 'undefined') {
            window.jQuery('#filterCihazTuru').on('select2:select select2:clear', onFilterTypeChanged);
        }

        const onEklemeTypeChanged = async () => {
            await loadBrands('eklemeCihazTuru', 'eklemeMarka');
            toggleOtherFields('eklemeCihazTuru', 'eklemeMarka', 'digerTurWrap', 'digerMarkaWrap');
        };

        document.getElementById('eklemeCihazTuru')?.addEventListener('change', onEklemeTypeChanged);
        if (typeof window.jQuery !== 'undefined') {
            window.jQuery('#eklemeCihazTuru').on('select2:select select2:clear', onEklemeTypeChanged);
        }

        document.getElementById('eklemeMarka')?.addEventListener('change', function () {
            toggleOtherFields('eklemeCihazTuru', 'eklemeMarka', 'digerTurWrap', 'digerMarkaWrap');
        });

        if (Number(yeniCihazId) > 0) {
            const yeniSatir = document.getElementById(`cihaz-row-${yeniCihazId}`);
            if (yeniSatir) {
                yeniSatir.classList.add('highlight-new');
                yeniSatir.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(() => yeniSatir.classList.remove('highlight-new'), 3000);
            }
        }

        if (cihazEkleModalElement) {
            cihazEkleModalElement.addEventListener('shown.bs.modal', async function () {
                const eklemeTur = document.getElementById('eklemeCihazTuru');
                const filtreTur = document.getElementById('filterCihazTuru');
                if (eklemeTur && filtreTur && eklemeTur.options.length <= 1 && filtreTur.options.length > 1) {
                    eklemeTur.innerHTML = '<option value="">Se\u00e7iniz</option>';
                    Array.from(filtreTur.options)
                        .filter(o => o.value)
                        .forEach(o => {
                            const opt = document.createElement('option');
                            opt.value = o.value;
                            opt.textContent = o.textContent;
                            eklemeTur.appendChild(opt);
                        });
                    refreshSelect2(eklemeTur);
                }

                await loadDeviceTypesIntoModal();
                await loadBrands('eklemeCihazTuru', 'eklemeMarka');
            });
        }
    </script>
}

@model PersonelTakipSistemi.ViewModels.YazilimDetayViewModel
@{
    ViewData["Title"] = "Yazılım Detayı";
    var returnAction = (string?)ViewBag.ReturnAction ?? "BenimYazilimlarim";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="mb-3">
        <a asp-action="@returnAction" class="btn btn-label-secondary"><i class="bx bx-arrow-back me-1"></i> Geri Dön</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-lg-12 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@Model.YazilimAdi - @Model.Surum</h5>
                    <div class="d-flex gap-2">
                        @if (Model.OnayYetkisiVarMi)
                        {
                            <form asp-action="YazilimOnaylaDetay" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="yazilimKaydiId" value="@Model.YazilimKaydiId" />
                                <input type="hidden" name="returnAction" value="@returnAction" />
                                <button type="submit" class="btn btn-warning">Onayla</button>
                            </form>
                        }
                        @if (Model.DuzenlemeYetkisiVarMi)
                        {
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#yazilimDuzenleModal">Düzenle</button>
                        }
                        @if (Model.DevirYetkisiVarMi)
                        {
                            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#yazilimDevirModal">Yazılımı Devret</button>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="YazilimSilDetay" method="post" class="d-inline" onsubmit="return confirm('Bu yazılım kaydını silmek istediğinize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="yazilimKaydiId" value="@Model.YazilimKaydiId" />
                                <input type="hidden" name="returnAction" value="@returnAction" />
                                <button type="submit" class="btn btn-danger">Sil</button>
                            </form>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label text-muted">Yazılım Sahibi</label><div class="fw-semibold">@Model.SahipAdSoyad</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Koordinatörlük</label><div class="fw-semibold">@Model.KoordinatorlukAd</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Sürüm</label><div class="fw-semibold">@Model.Surum</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Lisans Anahtarı / Hesap Bilgisi</label><div class="fw-semibold">@Model.LisansAnahtari</div></div>
                        <div class="col-md-4"><label class="form-label text-muted">Lisans Süresi Türü</label><div class="fw-semibold">@Model.LisansSuresiTuru</div></div>
                        <div class="col-md-4"><label class="form-label text-muted">Başlangıç Tarihi</label><div class="fw-semibold">@(Model.BaslangicTarihi.HasValue ? Model.BaslangicTarihi.Value.ToString("dd.MM.yyyy") : "-")</div></div>
                        <div class="col-md-4"><label class="form-label text-muted">Bitiş Tarihi</label><div class="fw-semibold">@(Model.BitisTarihi.HasValue ? Model.BitisTarihi.Value.ToString("dd.MM.yyyy") : "-")</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Kullanıcı Adı</label><div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.KullaniciAdi) ? "-" : Model.KullaniciAdi)</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">E-posta</label><div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Eposta) ? "-" : Model.Eposta)</div></div>
                        <div class="col-md-12"><label class="form-label text-muted">Özellikler</label><div class="border rounded bg-light p-3">@Model.Ozellikler</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">@Model.KayitTarihiBasligi</label><div class="fw-semibold">@Model.GosterilecekKayitTarihi.ToString("dd.MM.yyyy HH:mm")</div></div>
                        <div class="col-md-6"><label class="form-label text-muted">Durum</label><div><span class="badge @(Model.OnayDurumu == PersonelTakipSistemi.Models.YazilimOnayDurumu.Onaylandi ? "bg-label-success" : "bg-label-warning")">@(Model.OnayDurumu == PersonelTakipSistemi.Models.YazilimOnayDurumu.Onaylandi ? "Onaylı" : "Onay Bekliyor")</span></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.HareketlerGorunsunMu)
    {
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Yazılım Hareketliliği</h5></div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>İşlem</th>
                            <th>İşlem Yapan</th>
                            <th>Detay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hareket in Model.Hareketler)
                        {
                            <tr>
                                <td>@hareket.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@hareket.HareketTuru</td>
                                <td>
                                    <span class="@(hareket.IslemYapanCizili ? "text-decoration-line-through" : "")">@hareket.IslemYapan</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(hareket.OncekiSahip))
                                    {
                                        <span class="me-2">
                                            Önceki:
                                            <span class="@(hareket.OncekiSahipCizili ? "text-decoration-line-through" : "")">@hareket.OncekiSahip</span>
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hareket.YeniSahip))
                                    {
                                        <span class="me-2">
                                            Yeni:
                                            <span class="@(hareket.YeniSahipCizili ? "text-decoration-line-through" : "")">@hareket.YeniSahip</span>
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hareket.Aciklama))
                                    {
                                        <span>@hareket.Aciklama</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hareket.DurumNotu))
                                    {
                                        <span> | Not: @hareket.DurumNotu</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (Model.DuzenlemeYetkisiVarMi)
{
    <div class="modal fade" id="yazilimDuzenleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="YazilimGuncelle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="YazilimKaydiId" value="@Model.DuzenleFormu.YazilimKaydiId" />
                    <input type="hidden" name="returnAction" value="@returnAction" />
                    <div class="modal-header">
                        <h5 class="modal-title">@(Model.DuzenlemeOnayGerekliMi ? "Düzenlemeyi Onaya Gönder" : "Yazılımı Düzenle / Normalize Et")</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Yazılım</label>
                                <select name="YazilimId" class="form-select searchable-select" id="duzenleYazilim">
                                    <option value="">Seçiniz</option>
                                    @foreach (var item in Model.YazilimTanimlari)
                                    {
                                        if (item.Id == Model.DuzenleFormu.YazilimId)
                                        {
                                            <option value="@item.Id" selected>@item.Ad</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Ad</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-12 @(Model.DuzenleFormu.YazilimId == Model.DigerYazilimId ? "" : "d-none")" id="duzenleDigerYazilimWrap">
                                <label class="form-label">Diğer Yazılım</label>
                                <input name="DigerYazilimAd" value="@Model.DuzenleFormu.DigerYazilimAd" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Sürüm</label>
                                <input name="Surum" value="@Model.DuzenleFormu.Surum" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Lisans Anahtarı / Hesap Bilgisi</label>
                                <input name="LisansAnahtari" value="@Model.DuzenleFormu.LisansAnahtari" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Lisans Süresi Türü</label>
                                <select name="LisansSuresiTuru" class="form-select lisans-sure-turu" data-prefix="duzenle">
                                    @if (Model.DuzenleFormu.LisansSuresiTuru == PersonelTakipSistemi.Models.LisansSuresiTuru.Aylik)
                                    {
                                        <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Aylik)" selected>Aylık</option>
                                    }
                                    else
                                    {
                                        <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Aylik)">Aylık</option>
                                    }
                                    @if (Model.DuzenleFormu.LisansSuresiTuru == PersonelTakipSistemi.Models.LisansSuresiTuru.Yillik)
                                    {
                                        <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Yillik)" selected>Yıllık</option>
                                    }
                                    else
                                    {
                                        <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Yillik)">Yıllık</option>
                                    }
                                    @if (Model.DuzenleFormu.LisansSuresiTuru == PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)
                                    {
                                        <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)" selected>Süresiz</option>
                                    }
                                    else
                                    {
                                        <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)">Süresiz</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Başlangıç Tarihi</label>
                                <input name="BaslangicTarihi" value="@(Model.DuzenleFormu.BaslangicTarihi?.ToString("yyyy-MM-dd"))" type="date" class="form-control lisans-baslangic" data-prefix="duzenle" />
                            </div>
                            <div class="col-md-4 lisans-bitis-wrap" data-prefix="duzenle">
                                <label class="form-label">Bitiş Tarihi</label>
                                <input name="BitisTarihi" value="@(Model.DuzenleFormu.BitisTarihi?.ToString("yyyy-MM-dd"))" type="date" class="form-control lisans-bitis" data-prefix="duzenle" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kullanıcı Adı</label>
                                <input name="KullaniciAdi" value="@Model.DuzenleFormu.KullaniciAdi" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-posta</label>
                                <input name="Eposta" value="@Model.DuzenleFormu.Eposta" type="email" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Özellikler</label>
                                <input name="Ozellikler" value="@Model.DuzenleFormu.Ozellikler" class="form-control" />
                            </div>
                            <div class="col-12">
                                <div class="alert alert-info mb-0">
                                    @(Model.DuzenlemeOnayGerekliMi
                                        ? "Bu düzenleme onaya gönderilir. Yazılım tekrar admin veya koordinatör onayı bekler."
                                        : "Bu düzenleme hareket geçmişine yazılmaz; sistem logunda görünür.")
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">@(Model.DuzenlemeOnayGerekliMi ? "Onaya Gönder" : "Kaydet")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.DevirYetkisiVarMi)
{
    <div class="modal fade" id="yazilimDevirModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="YazilimDevret" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="YazilimKaydiId" value="@Model.DevirFormu.YazilimKaydiId" />
                    <input type="hidden" name="returnAction" value="@returnAction" />
                    <div class="modal-header">
                        <h5 class="modal-title">Yazılımı Devret</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Mevcut Sahip</label>
                            <input class="form-control" value="@Model.SahipAdSoyad" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Devredilecek Personel</label>
                            <select name="YeniSahipPersonelId" class="form-select searchable-select" id="yazilimDevirYeniSahipPersonelId">
                                <option value="">Seçiniz</option>
                                @foreach (var item in Model.DevredilebilirPersoneller)
                                {
                                    <option value="@item.Id">@item.Ad</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Devir Notu</label>
                            <textarea name="DevirNotu" class="form-control" rows="3">@Model.DevirFormu.DevirNotu</textarea>
                        </div>
                        <div>
                            <label class="form-label">Yazılım Notu</label>
                            <textarea name="YazilimDurumNotu" class="form-control" rows="3">@Model.DevirFormu.YazilimDurumNotu</textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-success">Devret</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const yazilimDigerId = '@Model.DigerYazilimId';

        function initDetailSearchableSelects() {
            if (typeof window.jQuery === 'undefined' || typeof window.jQuery.fn.select2 === 'undefined') return;
            const $ = window.jQuery;
            $('.searchable-select').each(function () {
                const $el = $(this);
                if ($el.hasClass('select2-hidden-accessible')) return;
                const modalParent = $el.closest('.modal');
                $el.select2({
                    theme: 'bootstrap-5',
                    width: '100%',
                    placeholder: 'Seçiniz',
                    allowClear: true,
                    dropdownParent: modalParent.length ? modalParent : undefined
                });
            });
        }

        function toggleOtherEditFields() {
            const select = document.getElementById('duzenleYazilim');
            document.getElementById('duzenleDigerYazilimWrap')?.classList.toggle('d-none', select?.value !== yazilimDigerId);
        }

        function toggleDateFields(prefix) {
            const sureTuru = document.querySelector(`.lisans-sure-turu[data-prefix="${prefix}"]`);
            const baslangic = document.querySelector(`.lisans-baslangic[data-prefix="${prefix}"]`);
            const bitis = document.querySelector(`.lisans-bitis[data-prefix="${prefix}"]`);
            const bitisWrap = document.querySelector(`.lisans-bitis-wrap[data-prefix="${prefix}"]`);
            if (!sureTuru || !baslangic || !bitis || !bitisWrap) return;
            const suresizValue = '@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)';
            const isSuresiz = sureTuru.value === suresizValue;
            bitisWrap.classList.toggle('d-none', isSuresiz);
            baslangic.required = !isSuresiz;
            bitis.required = !isSuresiz;
            if (isSuresiz) bitis.value = '';
        }

        document.getElementById('duzenleYazilim')?.addEventListener('change', toggleOtherEditFields);
        if (typeof window.jQuery !== 'undefined') {
            window.jQuery('#duzenleYazilim').on('select2:select select2:clear', toggleOtherEditFields);
        }

        document.querySelectorAll('.lisans-sure-turu').forEach(select => {
            const prefix = select.getAttribute('data-prefix');
            select.addEventListener('change', () => toggleDateFields(prefix));
            toggleDateFields(prefix);
        });

        initDetailSearchableSelects();
        toggleOtherEditFields();
    </script>
}

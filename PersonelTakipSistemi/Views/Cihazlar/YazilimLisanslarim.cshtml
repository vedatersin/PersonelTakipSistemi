@model PersonelTakipSistemi.ViewModels.YazilimLisanslarimViewModel
@{
    ViewData["Title"] = "Yaz&#305;l&#305;m Lisanslar&#305;m";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Profilim /</span> Yaz&#305;l&#305;m Lisanslar&#305;m</h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Yaz&#305;l&#305;m Ad&#305;</th>
                        <th>Lisans S&#252;resi T&#252;r&#252;</th>
                        <th>Ba&#351;lang&#305;&#231; Tarihi</th>
                        <th>Biti&#351; Tarihi</th>
                        <th>Kullan&#305;c&#305; Ad&#305;</th>
                        <th>E-posta</th>
                        <th>Durum</th>
                        <th>&#304;&#351;lemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Lisanslar.Any())
                    {
                        @foreach (var item in Model.Lisanslar)
                        {
                            <tr>
                                <td>@item.YazilimAdi</td>
                                <td>@item.LisansSuresiTuru</td>
                                <td>@(item.BaslangicTarihi.HasValue ? item.BaslangicTarihi.Value.ToString("dd.MM.yyyy") : "-")</td>
                                <td>@(item.BitisTarihi.HasValue ? item.BitisTarihi.Value.ToString("dd.MM.yyyy") : "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(item.KullaniciAdi) ? "-" : item.KullaniciAdi)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Eposta) ? "-" : item.Eposta)</td>
                                <td>
                                    <span class="badge @(item.OnayDurumu == "Onaylandı" ? "bg-label-success" : "bg-label-warning")">@item.OnayDurumu</span>
                                </td>
                                <td class="text-nowrap">
                                    @if (item.OnayIslemleriGoster)
                                    {
                                        <button type="button" class="btn btn-sm btn-primary"
                                                data-bs-toggle="modal" data-bs-target="#personelOnayModal"
                                                data-kayit-id="@item.YazilimLisansKullaniciId"
                                                data-lisans-id="@item.YazilimLisansId"
                                                data-kullanici-adi="@item.KullaniciAdi"
                                                data-eposta="@item.Eposta">
                                            Onay &#304;&#351;lemleri
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Tan&#305;ml&#305; yaz&#305;l&#305;m lisans&#305; bulunmuyor.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="modal fade" id="uyariModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Uyarı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">@TempData["ErrorMessage"]</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Tamam</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="personelOnayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="YazilimLisansKullaniciOnayaGonder" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="YazilimLisansKullaniciId" id="personelOnayKayitId" />
                <input type="hidden" name="YazilimLisansId" id="personelOnayLisansId" />
                <div class="modal-header">
                    <h5 class="modal-title">Onay &#304;&#351;lemleri</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Kullan&#305;c&#305; Ad&#305;</label>
                        <input type="text" name="KullaniciAdi" id="personelOnayKullaniciAdi" class="form-control" required />
                    </div>
                    <div>
                        <label class="form-label">E-posta</label>
                        <input type="email" name="Eposta" id="personelOnayEposta" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">&#304;ptal</button>
                    <button type="submit" class="btn btn-primary">Onaya G&#246;nder</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('personelOnayModal')?.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            document.getElementById('personelOnayKayitId').value = button.getAttribute('data-kayit-id') || '';
            document.getElementById('personelOnayLisansId').value = button.getAttribute('data-lisans-id') || '';
            document.getElementById('personelOnayKullaniciAdi').value = button.getAttribute('data-kullanici-adi') || '';
            document.getElementById('personelOnayEposta').value = button.getAttribute('data-eposta') || '';
        });

        const uyariModalEl = document.getElementById('uyariModal');
        if (uyariModalEl && typeof bootstrap !== 'undefined') {
            bootstrap.Modal.getOrCreateInstance(uyariModalEl).show();
        }
    </script>
}

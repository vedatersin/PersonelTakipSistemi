@model PersonelTakipSistemi.ViewModels.YazilimListePageViewModel
@{
    ViewData["Title"] = Model.Baslik;
    var showIslemlerKolonu = Model.AdminPaneliMi || Model.OnayYetkisiVarMi;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold py-3 mb-0"><span class="text-muted fw-light">Yazılımlar ve Cihazlar /</span> @Model.Baslik</h4>
        @if (Model.YazilimEklemeYetkisiVarMi)
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#yazilimEkleModal">+ Ekle</button>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    <form id="ajaxAntiForgeryForm" class="d-none">@Html.AntiForgeryToken()</form>

    @if (!Model.PersonelGorunumuMu)
    {
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3">
                    @if (Model.Koordinatorlukler.Any())
                    {
                        <div class="col-md-3">
                            <label class="form-label">Koordinatörlük</label>
                            <select asp-for="Filter.KoordinatorlukId" class="form-select searchable-select">
                                <option value="">Tümü</option>
                                @foreach (var item in Model.Koordinatorlukler)
                                {
                                    <option value="@item.Id">@item.Ad</option>
                                }
                            </select>
                        </div>
                    }
                    @if (Model.Personeller.Any())
                    {
                        <div class="col-md-3">
                            <label class="form-label">Personel</label>
                            <select asp-for="Filter.PersonelId" class="form-select searchable-select">
                                <option value="">Tümü</option>
                                <option value="-1">Sahipsiz</option>
                                @foreach (var item in Model.Personeller)
                                {
                                    <option value="@item.Id">@item.Ad</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-3">
                        <label class="form-label">Yazılım</label>
                        <select asp-for="Filter.YazilimId" class="form-select searchable-select">
                            <option value="">Tümü</option>
                            @foreach (var item in Model.YazilimTanimlari)
                            {
                                <option value="@item.Id">@item.Ad</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Sürüm</label>
                        <input asp-for="Filter.SurumAra" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Özellik</label>
                        <input asp-for="Filter.OzellikAra" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Lisans Anahtarı</label>
                        <input asp-for="Filter.LisansAnahtariAra" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label d-block">Kayıt Yaşı</label>
                        <input asp-for="Filter.YasSliderDegeri" type="hidden" id="yasSliderDegeri" />
                        <div class="kayit-yasi-slider-wrap">
                            <input type="range"
                                   id="kayitYasiSlider"
                                   min="0"
                                   max="6"
                                   step="1"
                                   class="kayit-yasi-slider"
                                   value="@(Model.Filter.YasSliderDegeri >= 0 && Model.Filter.YasSliderDegeri <= 6 ? Model.Filter.YasSliderDegeri : 0)"
                                   data-initial="@Model.Filter.YasSliderDegeri" />
                            <div id="kayitYasiAktifEtiket" class="kayit-yasi-aktif">Tümü</div>
                        </div>
                    </div>
                    @if (Model.OnayYetkisiVarMi)
                    {
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="Filter.SadeceOnayBekleyenler" class="form-check-input" />
                                <label asp-for="Filter.SadeceOnayBekleyenler" class="form-check-label">Sadece onay bekleyenler</label>
                            </div>
                        </div>
                    }
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Filtrele</button>
                        <a asp-action="@(Model.PersonelGorunumuMu ? "BenimYazilimlarim" : "Yazilimlar")" class="btn btn-label-secondary">Temizle</a>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th class="col-software-name">Yazılım</th>
                        <th>Sürüm</th>
                        <th>Özellikler</th>
                        <th>Lisans</th>
                        <th class="col-owner">Yazılım Sahibi</th>
                        <th>Koordinatörlük</th>
                        <th class="col-onay">Koordinatör Onayı</th>
                        @if (showIslemlerKolonu)
                        {
                            <th class="col-islemler">İşlemler</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Yazilimlar.Any())
                    {
                        @foreach (var item in Model.Yazilimlar)
                        {
                            <tr id="yazilim-row-@item.YazilimKaydiId" class="yazilim-row-clickable" data-detail-url="@Url.Action("YazilimDetay", new { id = item.YazilimKaydiId, returnAction = (Model.PersonelGorunumuMu ? "BenimYazilimlarim" : "Yazilimlar") })">
                                <td>@item.YazilimAdi</td>
                                <td>@item.Surum</td>
                                <td>@item.Ozellikler</td>
                                <td>@item.LisansSuresiTuru</td>
                                <td class="col-owner">@item.SahipAdSoyad</td>
                                <td>@item.KoordinatorlukAd</td>
                                <td class="col-onay">
                                    <span id="onay-badge-@item.YazilimKaydiId" class="badge @(item.OnayDurumu == PersonelTakipSistemi.Models.YazilimOnayDurumu.Onaylandi ? "bg-label-success" : "bg-label-warning")">
                                        @(item.OnayDurumu == PersonelTakipSistemi.Models.YazilimOnayDurumu.Onaylandi ? "Onaylandı" : "Onay Bekliyor")
                                    </span>
                                </td>
                                @if (showIslemlerKolonu)
                                {
                                    <td class="text-nowrap row-actions col-islemler">
                                        @if (Model.OnayYetkisiVarMi && item.OnayDurumu == PersonelTakipSistemi.Models.YazilimOnayDurumu.Beklemede)
                                        {
                                            <button type="button" class="btn btn-sm btn-success js-yazilim-onayla-btn" data-yazilim-id="@item.YazilimKaydiId">Onayla</button>
                                        }
                                        @if (Model.AdminPaneliMi)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-primary js-yazilim-hizli-duzenle-btn action-icon-btn"
                                                    title="Düzenle"
                                                    aria-label="Düzenle"
                                                    data-yazilim-kaydi-id="@item.YazilimKaydiId"
                                                    data-yazilim-id="@item.YazilimId"
                                                    data-diger-yazilim="@item.DigerYazilimAd"
                                                    data-surum="@item.Surum"
                                                    data-ozellikler="@item.Ozellikler"
                                                    data-lisans="@item.LisansAnahtari"
                                                    data-sure="@((int)item.LisansSuresiTuruValue)"
                                                    data-baslangic="@(item.BaslangicTarihi?.ToString("yyyy-MM-dd"))"
                                                    data-bitis="@(item.BitisTarihi?.ToString("yyyy-MM-dd"))"
                                                    data-kullanici-adi="@item.KullaniciAdi"
                                                    data-eposta="@item.Eposta">
                                                <i class="bx bx-edit-alt"></i>
                                            </button>
                                            <button type="button"
                                                    class="btn btn-sm btn-danger js-yazilim-sil-btn action-icon-btn"
                                                    title="Sil"
                                                    aria-label="Sil"
                                                    data-yazilim-id="@item.YazilimKaydiId">
                                                <i class="bx bx-trash"></i>
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="@(showIslemlerKolonu ? 8 : 7)" class="text-center text-muted py-4">Yazılım kaydı bulunamadı.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.YazilimEklemeYetkisiVarMi)
{
    <div class="modal fade" id="yazilimEkleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="YazilimEkle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnAction" value="@(Model.PersonelGorunumuMu ? "BenimYazilimlarim" : "Yazilimlar")" />
                    <div class="modal-header">
                        <h5 class="modal-title">Yazılım Ekle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            @if (Model.EklemeIcinPersoneller.Any() && !Model.PersonelGorunumuMu)
                            {
                                <div class="col-12">
                                    <label class="form-label">Yazılım Sahibi</label>
                                    <select asp-for="YeniYazilim.SahipPersonelId" class="form-select searchable-select">
                                        <option value="">Seçiniz</option>
                                        @foreach (var item in Model.EklemeIcinPersoneller)
                                        {
                                            <option value="@item.Id">@item.Ad</option>
                                        }
                                    </select>
                                </div>
                            }
                            <div class="col-12">
                                <label class="form-label">Yazılım</label>
                                <select asp-for="YeniYazilim.YazilimId" class="form-select searchable-select js-yazilim-select" id="eklemeYazilim">
                                    <option value="">Seçiniz</option>
                                    @foreach (var item in Model.EklemeIcinYazilimlar)
                                    {
                                        <option value="@item.Id">@item.Ad</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 d-none diger-vurgu-hedef" id="digerYazilimWrap">
                                <label class="form-label">Diğer Yazılım</label>
                                <input asp-for="YeniYazilim.DigerYazilimAd" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Sürüm</label>
                                <input asp-for="YeniYazilim.Surum" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Lisans Anahtarı / Hesap Bilgisi</label>
                                <input asp-for="YeniYazilim.LisansAnahtari" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Lisans Süresi Türü</label>
                                <select asp-for="YeniYazilim.LisansSuresiTuru" class="form-select lisans-sure-turu" data-prefix="ekle">
                                    <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Aylik)">Aylık</option>
                                    <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Yillik)">Yıllık</option>
                                    <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)">Süresiz</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Başlangıç Tarihi</label>
                                <input asp-for="YeniYazilim.BaslangicTarihi" type="date" class="form-control lisans-baslangic" data-prefix="ekle" />
                            </div>
                            <div class="col-md-4 lisans-bitis-wrap" data-prefix="ekle">
                                <label class="form-label">Bitiş Tarihi</label>
                                <input asp-for="YeniYazilim.BitisTarihi" type="date" class="form-control lisans-bitis" data-prefix="ekle" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kullanıcı Adı</label>
                                <input asp-for="YeniYazilim.KullaniciAdi" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-posta</label>
                                <input asp-for="YeniYazilim.Eposta" type="email" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Özellikler</label>
                                <input asp-for="YeniYazilim.Ozellikler" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">@(Model.PersonelGorunumuMu ? "Onaya Gönder" : "Gönder")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.AdminPaneliMi)
{
    <div class="modal fade" id="yazilimHizliDuzenleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form id="yazilimHizliDuzenleForm">
                    <div class="modal-header">
                        <h5 class="modal-title">Yazılımı Hızlı Düzenle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hizliYazilimKaydiId" />
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Yazılım</label>
                                <select class="form-select searchable-select js-yazilim-select" id="hizliYazilimId" required>
                                    <option value="">Seçiniz</option>
                                    @foreach (var item in Model.YazilimTanimlari)
                                    {
                                        <option value="@item.Id">@item.Ad</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 d-none diger-vurgu-hedef" id="hizliDigerYazilimWrap">
                                <label class="form-label">Diğer Yazılım</label>
                                <input type="text" class="form-control" id="hizliDigerYazilimAd" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Sürüm</label>
                                <input type="text" class="form-control" id="hizliSurum" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Lisans Anahtarı / Hesap Bilgisi</label>
                                <input type="text" class="form-control" id="hizliLisansAnahtari" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Lisans Süresi Türü</label>
                                <select class="form-select lisans-sure-turu" id="hizliSureTuru" data-prefix="hizli">
                                    <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Aylik)">Aylık</option>
                                    <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Yillik)">Yıllık</option>
                                    <option value="@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)">Süresiz</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Başlangıç Tarihi</label>
                                <input type="date" class="form-control lisans-baslangic" id="hizliBaslangic" data-prefix="hizli" />
                            </div>
                            <div class="col-md-4 lisans-bitis-wrap" data-prefix="hizli">
                                <label class="form-label">Bitiş Tarihi</label>
                                <input type="date" class="form-control lisans-bitis" id="hizliBitis" data-prefix="hizli" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kullanıcı Adı</label>
                                <input type="text" class="form-control" id="hizliKullaniciAdi" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-posta</label>
                                <input type="email" class="form-control" id="hizliEposta" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Özellikler</label>
                                <input type="text" class="form-control" id="hizliOzellikler" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        .kayit-yasi-slider-wrap { --slider-fill: 0%; }
        .kayit-yasi-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 10px;
            border-radius: 999px;
            outline: none;
            background: linear-gradient(to right, #696cff 0%, #696cff var(--slider-fill), #d9dee3 var(--slider-fill), #d9dee3 100%);
        }
        .kayit-yasi-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid #696cff;
            box-shadow: 0 1px 4px rgba(67, 89, 113, 0.25);
            cursor: pointer;
            margin-top: -4px;
        }
        .kayit-yasi-slider::-moz-range-thumb {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid #696cff;
            box-shadow: 0 1px 4px rgba(67, 89, 113, 0.25);
            cursor: pointer;
        }
        .kayit-yasi-aktif {
            margin-top: 0.65rem;
            min-height: 1.25rem;
            color: #566a7f;
            font-size: 0.8125rem;
            font-weight: 600;
            text-align: center;
        }
        @@keyframes highlightBlue {
            0% { background-color: rgba(13, 110, 253, 0.32); }
            100% { background-color: transparent; }
        }
        .highlight-new { animation: highlightBlue 3s ease-out; }
        .yazilim-row-clickable { cursor: pointer; }
        .yazilim-row-clickable:hover > td { background: #f8f9fb; }
        .row-actions { min-width: 138px; }
        .col-software-name { min-width: 160px; width: 16%; }
        .col-owner { min-width: 180px; width: 20%; }
        .col-onay { width: 135px; white-space: nowrap; }
        .col-islemler { width: 145px; white-space: nowrap; }
        .action-icon-btn i { font-size: 1.5em; color: #fff; vertical-align: middle; }
        .modal .select2-container--open { z-index: 2000; }
        .modal .select2-dropdown { z-index: 2001; }
    </style>
}

@section Scripts {
    <script>
        const yeniYazilimKaydiId = '@TempData["NewYazilimKaydiId"]';
        const yazilimDigerId = '@Model.DigerYazilimId';
        const yasSliderInput = document.getElementById('kayitYasiSlider');
        const yasSliderHiddenInput = document.getElementById('yasSliderDegeri');
        const yasSliderAktifEtiket = document.getElementById('kayitYasiAktifEtiket');
        const antiforgeryToken = document.querySelector('#ajaxAntiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';
        const yazilimHizliModalElement = document.getElementById('yazilimHizliDuzenleModal');
        const yazilimHizliModal = yazilimHizliModalElement ? new bootstrap.Modal(yazilimHizliModalElement) : null;
        const yasSliderEtiketleri = ['1 yıldan az', '1 yıldan fazla', '2 yıldan fazla', '3 yıldan fazla', '4 yıldan fazla', '5 yıldan fazla'];

        function updateYasSliderUI(isAllState = false) {
            if (!yasSliderInput || !yasSliderHiddenInput || !yasSliderAktifEtiket) return;
            const numericValue = Number(yasSliderInput.value || 0);
            const maxValue = Number(yasSliderInput.max || 6);
            const fillPercent = maxValue > 0 ? (numericValue / maxValue) * 100 : 0;
            yasSliderInput.style.setProperty('--slider-fill', `${fillPercent}%`);
            yasSliderAktifEtiket.textContent = isAllState ? 'Tümü' : (yasSliderEtiketleri[numericValue - 1] || yasSliderEtiketleri[0]);
        }

        if (yasSliderInput && yasSliderHiddenInput) {
            const initialHiddenValue = Number(yasSliderInput.dataset.initial ?? yasSliderHiddenInput.value ?? -1);
            const isAllState = initialHiddenValue < 0;
            if (isAllState) {
                yasSliderHiddenInput.value = -1;
                yasSliderInput.value = 0;
            }
            updateYasSliderUI(isAllState);
            yasSliderInput.addEventListener('input', function () {
                const value = Number(this.value || 0);
                yasSliderHiddenInput.value = value <= 0 ? -1 : value;
                updateYasSliderUI(value <= 0);
            });
        }

        function initSearchableSelects() {
            if (typeof window.jQuery === 'undefined' || typeof window.jQuery.fn.select2 === 'undefined') return;
            const $ = window.jQuery;
            $('.searchable-select').each(function () {
                const $el = $(this);
                if ($el.hasClass('select2-hidden-accessible')) return;
                const modalParent = $el.closest('.modal');
                $el.select2({
                    theme: 'bootstrap-5',
                    width: '100%',
                    placeholder: 'Seçiniz',
                    allowClear: true,
                    dropdownParent: modalParent.length ? modalParent : undefined
                });
            });
        }

        function toggleOtherSoftwareFields() {
            document.getElementById('digerYazilimWrap')?.classList.toggle('d-none', document.getElementById('eklemeYazilim')?.value !== yazilimDigerId);
            document.getElementById('hizliDigerYazilimWrap')?.classList.toggle('d-none', document.getElementById('hizliYazilimId')?.value !== yazilimDigerId);
        }

        function toggleDateFields(prefix) {
            const sureTuru = document.querySelector(`.lisans-sure-turu[data-prefix="${prefix}"]`);
            const baslangic = document.querySelector(`.lisans-baslangic[data-prefix="${prefix}"]`);
            const bitis = document.querySelector(`.lisans-bitis[data-prefix="${prefix}"]`);
            const bitisWrap = document.querySelector(`.lisans-bitis-wrap[data-prefix="${prefix}"]`);
            if (!sureTuru || !baslangic || !bitis || !bitisWrap) return;
            const suresizValue = '@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)';
            const isSuresiz = sureTuru.value === suresizValue;
            bitisWrap.classList.toggle('d-none', isSuresiz);
            baslangic.required = !isSuresiz;
            bitis.required = !isSuresiz;
            if (isSuresiz) bitis.value = '';
        }

        document.querySelectorAll('.lisans-sure-turu').forEach(select => {
            const prefix = select.getAttribute('data-prefix');
            select.addEventListener('change', () => toggleDateFields(prefix));
            toggleDateFields(prefix);
        });

        document.getElementById('eklemeYazilim')?.addEventListener('change', toggleOtherSoftwareFields);
        document.getElementById('hizliYazilimId')?.addEventListener('change', toggleOtherSoftwareFields);
        if (typeof window.jQuery !== 'undefined') {
            window.jQuery('#eklemeYazilim,#hizliYazilimId').on('select2:select select2:clear', toggleOtherSoftwareFields);
        }

        document.querySelectorAll('.yazilim-row-clickable').forEach(row => {
            row.addEventListener('click', function (event) {
                if (event.target.closest('button, a, form, input, select, textarea')) return;
                window.location.href = this.dataset.detailUrl;
            });
        });

        document.querySelectorAll('.js-yazilim-onayla-btn').forEach(btn => {
            btn.addEventListener('click', async function (event) {
                event.stopPropagation();
                const id = this.dataset.yazilimId;
                const result = await postForm('@Url.Action("YazilimOnaylaHizli")', { yazilimKaydiId: id });
                if (result) {
                    const badge = document.getElementById(`onay-badge-${id}`);
                    if (badge) {
                        badge.className = 'badge bg-label-success';
                        badge.textContent = 'Onaylandı';
                    }
                    this.remove();
                }
            });
        });

        document.querySelectorAll('.js-yazilim-sil-btn').forEach(btn => {
            btn.addEventListener('click', async function (event) {
                event.stopPropagation();
                const id = this.dataset.yazilimId;
                if (!confirm('Bu yazılım kaydını silmek istediğinize emin misiniz?')) return;
                const result = await postForm('@Url.Action("YazilimSil")', { yazilimKaydiId: id });
                if (result) document.getElementById(`yazilim-row-${id}`)?.remove();
            });
        });

        document.querySelectorAll('.js-yazilim-hizli-duzenle-btn').forEach(btn => {
            btn.addEventListener('click', function (event) {
                event.stopPropagation();
                document.getElementById('hizliYazilimKaydiId').value = this.dataset.yazilimKaydiId || '';
                document.getElementById('hizliYazilimId').value = this.dataset.yazilimId || '';
                document.getElementById('hizliDigerYazilimAd').value = this.dataset.digerYazilim || '';
                document.getElementById('hizliSurum').value = this.dataset.surum || '';
                document.getElementById('hizliOzellikler').value = this.dataset.ozellikler || '';
                document.getElementById('hizliLisansAnahtari').value = this.dataset.lisans || '';
                document.getElementById('hizliSureTuru').value = this.dataset.sure || '@((int)PersonelTakipSistemi.Models.LisansSuresiTuru.Suresiz)';
                document.getElementById('hizliBaslangic').value = this.dataset.baslangic || '';
                document.getElementById('hizliBitis').value = this.dataset.bitis || '';
                document.getElementById('hizliKullaniciAdi').value = this.dataset.kullaniciAdi || '';
                document.getElementById('hizliEposta').value = this.dataset.eposta || '';
                if (typeof window.jQuery !== 'undefined') window.jQuery('#hizliYazilimId').trigger('change');
                toggleOtherSoftwareFields();
                toggleDateFields('hizli');
                yazilimHizliModal?.show();
            });
        });

        document.getElementById('yazilimHizliDuzenleForm')?.addEventListener('submit', async function (event) {
            event.preventDefault();
            const result = await postForm('@Url.Action("YazilimHizliGuncelle")', {
                YazilimKaydiId: document.getElementById('hizliYazilimKaydiId').value,
                YazilimId: document.getElementById('hizliYazilimId').value,
                DigerYazilimAd: document.getElementById('hizliDigerYazilimAd').value,
                Surum: document.getElementById('hizliSurum').value,
                Ozellikler: document.getElementById('hizliOzellikler').value,
                LisansAnahtari: document.getElementById('hizliLisansAnahtari').value,
                LisansSuresiTuru: document.getElementById('hizliSureTuru').value,
                BaslangicTarihi: document.getElementById('hizliBaslangic').value,
                BitisTarihi: document.getElementById('hizliBitis').value,
                KullaniciAdi: document.getElementById('hizliKullaniciAdi').value,
                Eposta: document.getElementById('hizliEposta').value
            });
            if (result) window.location.reload();
        });

        async function postForm(url, data) {
            const formData = new URLSearchParams();
            formData.append('__RequestVerificationToken', antiforgeryToken);
            Object.keys(data).forEach(key => formData.append(key, data[key] ?? ''));
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: formData.toString()
            });
            const result = await response.json();
            if (!response.ok || !result.success) {
                alert(result.message || 'İşlem sırasında hata oluştu.');
                return null;
            }
            return result;
        }

        if (yeniYazilimKaydiId) {
            document.getElementById(`yazilim-row-${yeniYazilimKaydiId}`)?.classList.add('highlight-new');
        }

        initSearchableSelects();
        toggleOtherSoftwareFields();
    </script>
}

@model PersonelTakipSistemi.ViewModels.PersonelDetayViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Personel Detay";
}

<div class="container-xxl flex-grow-1 container-p-y">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold py-3 mb-0">
            <span class="text-muted fw-light">Personel /</span> Detay
        </h4>
        @{
            var currentUserIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
            int.TryParse(currentUserIdStr, out int currentUserId);
            var currentUserRole = User.FindFirstValue(ClaimTypes.Role);
            
            bool isSelf = (Model.PersonelId == currentUserId);
            bool isAdmin = (currentUserRole == "Admin");
            bool isManager = (currentUserRole == "Yönetici");
            
            bool canEdit = isAdmin || isSelf;
            bool canDelete = false;

            if (isAdmin)
            {
                // Admin: Kendi hariç, Diğer Admin Hariç
                if (!isSelf && Model.SistemRol != "Admin")
                {
                    canDelete = true;
                }
            }
            // Yönetici: canDelete stays false for everyone else per requirement (cannot delete personnel).

            if (ViewBag.IsHighLevelReadOnly == true)
            {
                canEdit = false;
                canDelete = false;
            }
        }
        <div>
            @if (canEdit)
            {
                <a href="@Url.Action("Ekle", new { id = Model.PersonelId })" class="btn btn-primary me-2">Düzenle</a>
            }

            @if(canDelete)
            {
               <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">Sil</button>
            }
        </div>
    </div>

    <div class="row">
        <!-- Sol Kart: Profil -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="mx-auto mb-3">
                        @if (AvatarHelper.HasCustomPhoto(Model.FotografYolu))
                        {
                            <img src="@Model.FotografYolu" alt="Personel Foto" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                            <div class="avatar-initial rounded-circle bg-label-primary mx-auto" style="width: 150px; height: 150px; font-size: 3rem; display: none; align-items: center; justify-content: center;">
                                @AvatarHelper.GetInitials(Model.Ad, Model.Soyad)
                            </div>
                        }
                        else
                        {
                             <div class="avatar-initial rounded-circle bg-label-primary mx-auto" style="width: 150px; height: 150px; font-size: 3rem; display: flex; align-items: center; justify-content: center;">
                                @AvatarHelper.GetInitials(Model.Ad, Model.Soyad)
                            </div>
                        }
                    </div>
                    <h4 class="mb-1">@Model.Ad @Model.Soyad</h4>
                    <p class="text-muted mb-3">@Model.Brans</p>
                    
                    <div class="d-flex justify-content-center gap-2">
                        @if (Model.AktifMi)
                        {
                            <span class="badge bg-success">Aktif Personel</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif Personel</span>
                        }
                    </div>

                    <div class="mt-4 text-start">
                        <h6 class="text-muted small text-uppercase">Kurumsal Rolü</h6>
                        <ul class="list-unstyled mb-0">
                            @if (Model.KurumsalRoller != null && Model.KurumsalRoller.Any())
                            {
                                foreach (var rol in Model.KurumsalRoller)
                                {
                                    <li class="mb-2">
                                        <div class="d-flex align-items-center">
                                            <i class="bx bx-badge-check me-2 text-@rol.ColorClass"></i>
                                            <span class="@(rol.ColorClass == "danger" ? "text-danger" : "")">@rol.Title</span>
                                        </div>
                                        @if(!string.IsNullOrEmpty(rol.Subtitle))
                                        {
                                            <div class="small text-muted ms-4">@rol.Subtitle</div>
                                        }
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="text-muted">-</li>
                            }
                        </ul>
                    </div>

                    <div class="mt-4 text-start">
                        <h6 class="text-muted small text-uppercase">Sistem Yetkisi</h6>
                         <ul class="list-unstyled mb-0">
                             <li class="mb-2"><i class="bx bx-shield-quarter me-2 text-info"></i>@Model.SistemRol</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ Kart: Temel Bilgiler ve Detaylar -->
        <div class="col-md-8 mb-4">
            <div class="card mb-4">
                <h5 class="card-header">Temel Bilgiler</h5>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold" style="width: 35%;">TC Kimlik No</td>
                                        <td>@Model.TcKimlikNo</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Telefon</td>
                                        <td>@(string.IsNullOrEmpty(Model.Telefon) ? "-" : (Model.Telefon.Length >= 5 ? Model.Telefon.Substring(0, 3) + new string('*', Model.Telefon.Length - 5) + Model.Telefon.Substring(Model.Telefon.Length - 2) : new string('*', Model.Telefon.Length)))</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">E-posta</td>
                                        <td>@Model.Eposta</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Cinsiyet</td>
                                        <td>@Model.Cinsiyet</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Kayıt Tarihi</td>
                                        <td>@Model.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tbody>
                                     <tr>
                                        <td class="fw-bold" style="width: 35%;">Görevli İl</td>
                                        <td>@Model.GorevliIl</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Kadro İli</td>
                                        <td>@(Model.KadroIl ?? "-")</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Kadro İlçesi</td>
                                        <td>@(Model.KadroIlce ?? "-")</td>
                                    </tr>
                                     <tr>
                                        <td class="fw-bold">Kurum</td>
                                        <td>@Model.KadroKurum</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Alt Kartlar: Özellikler -->
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <h6 class="card-header">Kullandığı Yazılımlar</h6>
                        <div class="card-body">
                            @if (Model.Yazilimlar != null && Model.Yazilimlar.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var item in Model.Yazilimlar)
                                    {
                                        <span class="badge bg-label-primary">@item</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Veri yok.</span>
                            }
                        </div>
                    </div>
                </div>
                
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                         <h6 class="card-header">Uzmanlık Alanları</h6>
                        <div class="card-body">
                             @if (Model.Uzmanliklar != null && Model.Uzmanliklar.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var item in Model.Uzmanliklar)
                                    {
                                        <span class="badge bg-label-info">@item</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Veri yok.</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                         <h6 class="card-header">Görevler</h6>
                        <div class="card-body">
                             @if (Model.GorevTurleri != null && Model.GorevTurleri.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var item in Model.GorevTurleri)
                                    {
                                        <span class="badge bg-label-warning">@item</span>
                                    }
                                </div>
                            }
                             else
                            {
                                <span class="text-muted small">Veri yok.</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                     <div class="card h-100">
                         <h6 class="card-header">İş Niteliği</h6>
                        <div class="card-body">
                             @if (Model.IsNitelikleri != null && Model.IsNitelikleri.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var item in Model.IsNitelikleri)
                                    {
                                        <span class="badge bg-label-danger">@item</span>
                                    }
                                </div>
                            }
                             else
                            {
                                <span class="text-muted small">Veri yok.</span>
                            }
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</div>

<!-- Silme Modalı -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCenterTitle">Personel Silme</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col mb-3">
                        <p><strong>@Model.Ad @Model.Soyad</strong> adlı personeli silmek istediğinize emin misiniz?</p>
                        <p class="text-danger small mb-0">Bu işlem geri alınamaz.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <form asp-action="Sil" method="post">
                    <input type="hidden" name="id" value="@Model.PersonelId" />
                    <button type="submit" class="btn btn-danger">Evet, Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>
